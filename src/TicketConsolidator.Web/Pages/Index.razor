@page "/"
@using TicketConsolidator.Web.Services
@using TicketConsolidator.Web.Components
@using TicketConsolidator.Application.DTOs
@inject TicketService TicketService
@implements IDisposable

<PageTitle>Dashboard | TicketConsolidator</PageTitle>

<div class="dashboard-container">
    
    <!-- Controls Header -->
    <div class="glass-panel controls-bar animate-slide-up">
        <div class="input-group">
            <div class="search-icon-wrapper @(IsBusy ? "searching" : "")">
                 <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                 </svg>
            </div>
            <input class="glass-input search-input" 
                   @bind="TicketInput" 
                   @bind:event="oninput" 
                   placeholder="Enter Tickets (e.g. ENGAGE-1234, 11096)" />
        </div>
        
        <div class="actions">
            <button class="glass-button" @onclick="StartScan" disabled="@(IsBusy || _isScanning)">
                @if(IsBusy || _isScanning) 
                { 
                     <span class="btn-content"><span class="loader-mini"></span> Scanning...</span>
                } 
                else 
                { 
                     <span class="btn-content">⚡ Scan Tickets</span> 
                }
            </button>
            <button class="glass-button-secondary" @onclick="Clear" disabled="@IsBusy">
                <span class="btn-content">🗑️ Clear</span>
            </button>
        </div>
    </div>

    <!-- Main Grid -->
    <div class="dashboard-grid animate-fade-in" style="animation-delay: 0.1s;">
        <!-- Input Column -->
        <div class="grid-col upload-col">
            <div class="glass-card status-card">
                <div class="status-header">
                    <h4>Current Status</h4>
                    <span class="status-badge @(IsBusy ? "busy" : "idle")">
                        @(IsBusy ? "Processing" : "Idle")
                    </span>
                </div>
                <div class="status-body">
                    <div class="status-top-row">
                        <p class="status-msg" title="@TicketService.StatusMessage">@TicketService.StatusMessage</p>
                        <span class="progress-percent">@TicketService.ProgressValue%</span>
                    </div>
                    <div class="progress-container">
                         <div class="progress-bar-bg">
                            <div class="progress-bar-fill" style="width: @(TicketService.ProgressValue)%"></div>
                        </div>
                        <span class="progress-text">@TicketService.TicketsCount tickets found</span>
                    </div>
                </div>
            </div>

            <FileDropZone />

            <div class="action-stack glass-card p-4">
                 <h4 class="section-title">Actions</h4>
                 <button class="glass-button full-width" @onclick="Consolidate" 
                         disabled="@(IsListEmpty || TicketService.IsBusy)">
                     <span class="btn-content">🚀 Consolidate & Save</span>
                 </button>
                 
                 <button class="glass-button-secondary full-width" @onclick="OpenEmailDialog"
                         disabled="@(string.IsNullOrEmpty(TicketService.LastRunId) || TicketService.IsBusy)">
                      <span class="btn-content">📧 Create Release Email</span>
                 </button>
            </div>
        </div>

        <!-- Lists Column (Tables) -->
        <div class="grid-col">
            <ScriptList Title="Tables" Scripts="@TicketService.TableScripts" 
                        MoveUp="s => MoveItem(s, TicketService.TableScripts, -1)"
                        MoveDown="s => MoveItem(s, TicketService.TableScripts, 1)"
                        Remove="s => RemoveItem(s, TicketService.TableScripts)" />
        </div>

        <!-- Lists Column (SP) -->
        <div class="grid-col">
            <ScriptList Title="Stored Procedures" Scripts="@TicketService.SpScripts"
                        MoveUp="s => MoveItem(s, TicketService.SpScripts, -1)"
                        MoveDown="s => MoveItem(s, TicketService.SpScripts, 1)"
                        Remove="s => RemoveItem(s, TicketService.SpScripts)" />
        </div>
        
        <!-- Lists Column (Data) -->
        <div class="grid-col">
            <ScriptList Title="Data Scripts" Scripts="@TicketService.DataScripts"
                        MoveUp="s => MoveItem(s, TicketService.DataScripts, -1)"
                        MoveDown="s => MoveItem(s, TicketService.DataScripts, 1)"
                        Remove="s => RemoveItem(s, TicketService.DataScripts)" />
        </div>
    </div>
</div>

<!-- Components -->
<Spinner Visible="@TicketService.IsBusy" Text="@TicketService.StatusMessage" />

<ReleaseDetailsDialog @bind-IsVisible="ShowEmailDialog" 
                      @ref="emailDialog"
                      OnSubmit="CreateEmail" />

<SuccessDialog @bind-IsVisible="ShowSuccessDialog" 
               Path="@SuccessPath" />

<NoScriptsFoundDialog @bind-IsVisible="ShowNoScriptsDialog" />

<style>
    /* Layout Improvements - Single Screen Pro */
    .dashboard-container {
        display: flex;
        flex-direction: column;
        gap: 0;
        height: 100%;
        max-width: 100%;
        margin: 0;
        padding: 0;
        overflow: hidden; 
    }

    .controls-bar {
        display: flex;
        justify-content: space-between;
        padding: 0.5rem 1rem; /* Compact */
        align-items: center;
        gap: 1rem;
        flex-shrink: 0;
        /* Glass effect provided by common class, but we add layout specifics */
        z-index: 20;
    }

    .input-group {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        flex: 1;
        max-width: 600px;
    }
    
    }
    
    .search-icon-wrapper {
        color: var(--text-secondary);
        display: flex; align-items: center; justify-content: center;
        transition: color 0.3s;
    }
    .search-icon-wrapper.searching {
        color: var(--primary);
        animation: searchSpin 2s linear infinite;
    }
    @@keyframes searchSpin {
        0% { transform: rotate(0deg); }
        25% { transform: rotate(10deg); }
        75% { transform: rotate(-10deg); }
        100% { transform: rotate(0deg); }
    }
    
    /* .icon removed as replaced */
    
    .actions { display: flex; gap: 1rem; }

    .dashboard-grid {
        display: grid;
        grid-template-columns: 280px 1fr 1fr 1fr; /* Compact Sidebar */
        grid-template-rows: 1fr;
        gap: 0.8rem; /* Tight Gap */
        flex: 1;
        min-height: 0;
        padding: 0.8rem; /* Minimal Padding */
        overflow: hidden;
    }

    .grid-col {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        min-height: 0;
        overflow: hidden;
    }
    
    .upload-col {
        gap: 1.25rem;
    }
    
    .status-card {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        flex-shrink: 0;
        border: 1px solid rgba(255,255,255,0.06);
        background: rgba(24, 24, 27, 0.4); /* Zinc 900 semi-transparent */
    }

    .status-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .status-badge {
        font-size: 0.75rem;
        padding: 0.25rem 0.75rem;
        border-radius: var(--radius-pill);
        background: rgba(255, 255, 255, 0.05);
        color: var(--text-secondary);
        font-weight: 500;
        letter-spacing: 0.02em;
    }
    
    .status-badge.busy { background: rgba(139, 92, 246, 0.15); color: #c4b5fd; border: 1px solid rgba(139,92,246,0.3); animation: pulse 2s infinite; }
    .status-badge.idle { background: rgba(16, 185, 129, 0.1); color: #6ee7b7; border: 1px solid rgba(16,185,129,0.2); }
    
    @@keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.6; } 100% { opacity: 1; } }

    /* Progress Bar */
    .status-top-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.5rem;
    }
    
    .status-msg {
        margin: 0;
        font-size: 0.9rem;
        color: var(--text-primary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 200px;
    }

    .progress-percent {
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--primary);
        font-variant-numeric: tabular-nums;
    }

    .progress-container {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    
    .progress-bar-bg {
        height: 8px; /* Slightly thicker */
        background: rgba(255,255,255,0.08); 
        border-radius: var(--radius-pill);
        overflow: hidden;
    }
    
    .progress-bar-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--primary), var(--accent));
        transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 0 15px var(--primary-glow);
        position: relative;
    }

    .progress-bar-fill::after {
        content: '';
        position: absolute;
        top: 0; left: 0; bottom: 0; right: 0;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent);
        transform: translateX(-100%);
        animation: shimmer 2s infinite;
    }
    
    @@keyframes shimmer { 100% { transform: translateX(100%); } }
    
    .progress-text {
        font-size: 0.8rem; 
        color: var(--text-secondary);
        text-align: right;
    }

    /* Action Stack */
    .action-stack {
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
        margin-top: auto; 
        padding: 1.5rem;
        flex-shrink: 0;
    }
    
    .section-title {
        margin: 0 0 0.5rem 0;
        font-size: 0.8rem;
        color: var(--text-tertiary);
    }
    
    .full-width { width: 100%; justify-content: center; height: 42px; }
    
    /* Utility */
    .p-4 { padding: 1.5rem; }

    /* Loader Mini */
    .loader-mini {
        width: 16px; height: 16px;
        border: 2px solid rgba(255,255,255,0.2);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 1s linear infinite;
        display: inline-block;
    }
    
    @@keyframes spin { to { transform: rotate(360deg); } }
</style>

@code {
    private string TicketInput { get; set; }
    private bool IsBusy => TicketService.IsBusy;
    private bool IsListEmpty => (TicketService.TableScripts.Count + TicketService.SpScripts.Count + TicketService.DataScripts.Count) == 0;

    private bool ShowEmailDialog { get; set; }
    private ReleaseDetailsDialog emailDialog;

    // Success Dialog State
    private bool ShowSuccessDialog { get; set; }
    private string SuccessPath { get; set; }

    protected override void OnInitialized()
    {
        TicketService.OnChange += StateHasChanged;
        TicketService.OnConsolidationSuccess += HandleConsolidationSuccess;
    }
    
    public void Dispose()
    {
        TicketService.OnChange -= StateHasChanged;
        TicketService.OnConsolidationSuccess -= HandleConsolidationSuccess;
    }

    private async void HandleConsolidationSuccess(string path)
    {
        await InvokeAsync(() => 
        {
            SuccessPath = path;
            ShowSuccessDialog = true;
            StateHasChanged();
        });
    }

    private bool ShowNoScriptsDialog { get; set; }

    private bool _isScanning;

    private async Task StartScan()
    {
        _isScanning = true;
        StateHasChanged(); // Immediate button update
        
        try 
        {
            await TicketService.StartScanAsync(TicketInput);
        }
        finally 
        {
            _isScanning = false;
            StateHasChanged();
        }

        if (!IsListEmpty) 
        {
            // Found something
        }
        else if (!TicketService.IsBusy && IsListEmpty)
        {
             // Finished but nothing found
             ShowNoScriptsDialog = true;
        }
    }

    private void Clear()
    {
        TicketInput = "";
        TicketService.Clear();
    }

    private async Task Consolidate()
    {
        await TicketService.ConsolidateAsync();
    }

    private void OpenEmailDialog()
    {
        if (emailDialog != null)
        {
            emailDialog.SetDefaults(TicketService.LastRunId, TicketService.LastConsolidatedPath);
        }
        ShowEmailDialog = true;
    }

    private async Task CreateEmail()
    {
        if (emailDialog != null)
        {
             await TicketService.CreateReleaseEmailAsync(emailDialog.BuildNumber, emailDialog.SolutionPath, emailDialog.Username);
        }
    }

    private void MoveItem(Application.DTOs.SqlScript script, List<Application.DTOs.SqlScript> list, int direction)
    {
        int index = list.IndexOf(script);
        if (index < 0) return;
        
        int newIndex = index + direction;
        if (newIndex >= 0 && newIndex < list.Count)
        {
            var item = list[index];
            list.RemoveAt(index);
            list.Insert(newIndex, item);
            StateHasChanged();
        }
    }
    
    private void RemoveItem(Application.DTOs.SqlScript script, List<Application.DTOs.SqlScript> list)
    {
        list.Remove(script);
        StateHasChanged();
    }
}
