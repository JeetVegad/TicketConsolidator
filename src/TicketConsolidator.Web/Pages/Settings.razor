@page "/settings"
@using TicketConsolidator.Infrastructure.Services
@using TicketConsolidator.Application.Interfaces
@inject SettingsService SettingsService
@inject ILoggerService Logger
@inject Services.ToastService ToastService

<PageTitle>Settings | TicketConsolidator</PageTitle>

<div class="page-container d-flex justify-center" style="padding-top: 6rem; padding-bottom: 4rem; align-items: flex-start;">
    <div class="glass-card content-card animate-scale-in">
        <h2 class="page-title animate-fade-in delay-1">Application Settings</h2>
        
        <div class="settings-grid">
            <!-- Outlook Integration (Single Centered Group) -->
            <div class="settings-group animate-slide-up delay-2">
                <h3 class="group-title">Outlook Integration</h3>
                <div class="input-row">
                    <label>Target Folder Name</label>
                    <input class="glass-input" @bind="OutlookFolder" placeholder="Inbox" />
                    <p class="hint">Folder to scan (e.g. 'Inbox').</p>
                </div>
            </div>

            <!-- Email Template Configuration -->
            <div class="settings-group animate-slide-up delay-3">
                <h3 class="group-title">Email Notification Template</h3>
                <div class="input-row">
                    <label>Email Body (HTML Supported)</label>
                    <CodeEditor @bind-Value="EmailTemplate" />
                    
                    <div class="template-actions">
                        <button class="glass-button-secondary small" @onclick="TogglePreview">
                            <span class="btn-content">👁️ Preview</span>
                        </button>
                        <button class="glass-button-secondary small" @onclick="ResetTemplate">
                            <span class="btn-content">↺ Reset to Default</span>
                        </button>
                    </div>

                    @if (ShowPreview)
                    {
                        <div class="preview-box animate-fade-in">
                            <div class="preview-header">Preview Mode (Sample Data)</div>
                            <div class="preview-content custom-scroll">
                                @((MarkupString)PreviewHtml)
                            </div>
                        </div>
                    }

                    <div class="template-help">
                        <p class="hint">Available Placeholders:</p>
                        <ul class="hint-list">
                            <li><code>{BuildNumber}</code> - Current Build/Time ID</li>
                            <li><code>{SolutionPath}</code> - Release folder link</li>
                            <li><code>{FileList}</code> - Bullet list of SQL files</li>
                            <li><code>{ReleaseDetails}</code> - Table of Ticket IDs & Summaries</li>
                            <li><code>{UserName}</code> - Your name</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <div class="actions-row animate-fade-in delay-4">
            <button class="glass-button" @onclick="SaveSettings">
                <span class="btn-content">💾 Save Changes</span>
            </button>
            <span class="status-msg @(IsSaved ? "success" : "")">@StatusMessage</span>
        </div>
    </div>
</div>

<style>
    /* Local Overrides only where necessary */
    .content-card {
        width: 100%;
        max-width: 900px; /* Slightly wider for better editor view */
        display: flex;
        flex-direction: column;
        gap: 2rem;
        padding: 2.5rem; /* More internal breathing room */
    }
    
    .page-title { 
        margin: 0; 
        font-size: 1.75rem; 
        font-weight: 700;
        color: var(--text-primary);
        border-bottom: 1px solid rgba(255,255,255,0.05);
        padding-bottom: 1.5rem;
        text-align: center;
        letter-spacing: -0.02em;
    }
    
    .settings-grid {
        display: flex;
        flex-direction: column;
        gap: 3rem; /* significantly increased gap for separation */
    }
    
    .settings-group {
        display: flex;
        flex-direction: column;
        gap: 1.25rem; 
        position: relative;
    }
    
    .group-title {
        margin: 0 0 0.25rem 0;
        font-size: 0.8rem;
        color: var(--primary-light); 
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        opacity: 0.9;
    }
    
    .input-row {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }
    
    .input-row label {
        font-size: 0.95rem;
        color: var(--text-primary);
        font-weight: 500;
    }
    
    .hint { margin: 0; font-size: 0.85rem; color: var(--text-muted); }

    .template-help {
        margin-top: 1rem;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: var(--radius-sm);
        padding: 1rem;
    }

    .hint-list {
        margin: 0.5rem 0 0 1.25rem;
        padding: 0;
        font-size: 0.85rem;
        color: var(--text-secondary);
    }
    .hint-list li { margin-bottom: 0.4rem; }
    .hint-list code { 
        color: var(--accent-light); 
        background: rgba(0, 0, 0, 0.2); 
        padding: 2px 6px; 
        border-radius: 4px; 
        font-family: 'Consolas', monospace;
    }
    
    .template-actions { 
        display: flex; 
        justify-content: flex-end; 
        gap: 0.75rem; 
        margin-top: 0.75rem; 
    }
    
    .small { 
        padding: 0.4rem 1rem; 
        font-size: 0.85rem; 
    }


    .preview-box {
        margin-top: 1.5rem;
        background: white;
        border-radius: var(--radius-sm);
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.2);
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    }
    .preview-header {
        background: #f8f9fa;
        color: #495057;
        padding: 0.75rem 1rem;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        border-bottom: 1px solid #e9ecef;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .preview-content {
        padding: 1.5rem;
        color: #212529;
        font-family: Calibri, sans-serif;
        max-height: 400px;
        overflow-y: auto;
        font-size: 11pt; /* Match default email font size */
    }
    /* Simple reset for preview content to ensure it looks like a browser view */
    .preview-content ::deep p { margin: 0 0 10px 0; }
    .preview-content ::deep ul { margin: 0 0 10px 20px; padding: 0; }
    .preview-content ::deep table { width: 100%; border-collapse: collapse; margin-bottom: 10px; }
    .preview-content ::deep th { background-color: #f2f2f2; font-weight: bold; text-align: left; }
    .preview-content ::deep th, .preview-content ::deep td { border: 1px solid #ccc; padding: 6px; }
    
    .actions-row {
        position: sticky;
        bottom: 0;
        z-index: 50;
        
        /* Glass effect to match card but opaque enough to hide content behind */
        background: rgba(13, 17, 23, 0.98); 
        backdrop-filter: blur(12px);
        
        /* Expand to cover full width of card padding */
        margin: 2rem -2.5rem -2.5rem -2.5rem;
        padding: 1.5rem;
        
        /* Border and rounded corners at bottom */
        border-top: 1px solid rgba(255,255,255,0.1);
        border-bottom-left-radius: inherit;
        border-bottom-right-radius: inherit;

        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1.5rem;
    }
    
    .status-msg {
        font-size: 0.95rem;
        color: var(--text-secondary);
        opacity: 0;
        transition: opacity 0.3s ease;
        min-width: 150px; /* Prevent layout jump */
        text-align: center;
    }
    
    .status-msg.success {
        color: var(--success);
        opacity: 1;
    }
    
    .justify-center {
        justify-content: center;
    }
</style>

@code {
    private string OutlookFolder { get; set; }
    private string EmailTemplate { get; set; }
    
    // Kept for internal logic/preservation
    private string ScriptsPath { get; set; }
    private string ConsolidatedPath { get; set; }
    
    private string StatusMessage { get; set; }
    private bool IsSaved { get; set; }
    
    private bool ShowPreview { get; set; }
    private string PreviewHtml { get; set; }

    // Hardcoded default for reset logic (Must match Service)
    private const string DefaultTemplateRef = @"<html><body>
<p style='font-family:Calibri,sans-serif;font-size:11pt'>Hi All,</p>
<p style='font-family:Calibri,sans-serif;font-size:11pt'><b>Product Release Notification [Build {BuildNumber}]:</b></p>
<p style='font-family:Calibri,sans-serif;font-size:11pt'>Please find the consolidated release deliverables as below:</p>
<p style='font-family:Calibri,sans-serif;font-size:11pt'><b>Release Folder:</b> <a href='{SolutionPath}'>{SolutionPath}</a></p>
<p style='font-family:Calibri,sans-serif;font-size:11pt'><b>DB Scripts:</b></p>
<ul>
{FileList}
</ul>
<br/>
<p style='font-family:Calibri,sans-serif;font-size:11pt'><b>Release Includes:</b></p>
<table border='1' style='border-collapse:collapse;font-family:Calibri,sans-serif;font-size:10pt;width:80%'>
<tr style='background-color:#f2f2f2'><th>JIRA IDs</th><th>Summary</th></tr>
{ReleaseDetails}
</table>
<br/>
<p style='font-family:Calibri,sans-serif;font-size:11pt'>Regards,<br/>{UserName}</p>
</body></html>";

    protected override void OnInitialized()
    {
        OutlookFolder = SettingsService.CurrentTargetFolder;
        ScriptsPath = SettingsService.ScriptsPath;
        ConsolidatedPath = SettingsService.ConsolidatedScriptsPath;
        EmailTemplate = SettingsService.EmailTemplate;
    }

    private void TogglePreview()
    {
        if (!ShowPreview)
        {
            GeneratePreviewHtml();
            ShowPreview = true;
        }
        else
        {
            ShowPreview = false;
        }
    }

    private void GeneratePreviewHtml()
    {
        if (string.IsNullOrWhiteSpace(EmailTemplate))
        {
            PreviewHtml = "<i>Empty Template</i>";
            return;
        }

        // Mock Data
        string mockFileList = "<li>01_Auth_Table.sql</li><li>02_User_SP.sql</li><li>03_Data_Seed.sql</li>";
        string mockDetails = "<tr><td style='padding:4px'><b>TICKET-101</b></td><td style='padding:4px'>Fix login bug</td></tr>" +
                             "<tr><td style='padding:4px'><b>TICKET-102</b></td><td style='padding:4px'>Add user profile</td></tr>";

        PreviewHtml = EmailTemplate
            .Replace("{BuildNumber}", "20240115_1200")
            .Replace("{SolutionPath}", @"\\server\share\Rel_1.0")
            .Replace("{FileList}", mockFileList)
            .Replace("{ReleaseDetails}", mockDetails)
            .Replace("{UserName}", "John Doe");
    }

    private void ResetTemplate()
    {
        EmailTemplate = DefaultTemplateRef;
        Logger.LogInfo("User reset email template to default.");
        ToastService.ShowInfo("Template reset to default.");
        if (ShowPreview) GeneratePreviewHtml(); 
    }

    private async Task SaveSettings()
    {
        StatusMessage = "Saving...";
        StateHasChanged(); 
        
        await SettingsService.UpdateSettingsAsync(OutlookFolder, ScriptsPath, ConsolidatedPath, EmailTemplate);
        
        IsSaved = true;
        StatusMessage = "Saved!"; 
        
        Logger.LogSuccess($"Settings updated. OutlookFolder: {OutlookFolder}");
        ToastService.ShowSuccess("Settings saved successfully!");
        
        await Task.Delay(2000);
        IsSaved = false;
        StatusMessage = "";
        StateHasChanged();
    }
}
