@page "/settings"
@using TicketConsolidator.Infrastructure.Services
@using TicketConsolidator.Application.Interfaces
@inject SettingsService SettingsService
@inject ILoggerService Logger

<PageTitle>Settings | TicketConsolidator</PageTitle>

<div class="page-container d-flex align-center justify-center">
    <div class="glass-card content-card animate-scale-in">
        <h2 class="page-title animate-fade-in delay-1">Application Settings</h2>
        
        <div class="settings-grid">
            <!-- Outlook Integration (Single Centered Group) -->
            <div class="settings-group animate-slide-up delay-2">
                <h3 class="group-title">Outlook Integration</h3>
                <div class="input-row">
                    <label>Target Folder Name</label>
                    <input class="glass-input" @bind="OutlookFolder" placeholder="Inbox" />
                    <p class="hint">Folder to scan (e.g. 'Inbox').</p>
                </div>
            </div>
        </div>

        <div class="actions-row animate-fade-in delay-3">
            <button class="glass-button" @onclick="SaveSettings">
                <span class="btn-content">💾 Save Changes</span>
            </button>
            <span class="status-msg @(IsSaved ? "success" : "")">@StatusMessage</span>
        </div>
    </div>
</div>

<style>
    /* Local Overrides only where necessary */
    .content-card {
        width: 100%;
        max-width: 600px; /* Reduced width for single column */
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }
    
    .page-title { 
        margin: 0; 
        font-size: 1.5rem; 
        font-weight: 600;
        color: var(--text-primary);
        border-bottom: 1px solid rgba(255,255,255,0.05);
        padding-bottom: 1rem;
        text-align: center; /* Center Title */
    }
    
    .settings-grid {
        display: flex; /* Flex instead of grid for single column */
        flex-direction: column;
        gap: 1.5rem;
    }
    
    .settings-group {
        display: flex;
        flex-direction: column;
        gap: 1.5rem; 
    }
    
    .group-title {
        margin: 0 0 0.5rem 0;
        font-size: 0.85rem;
        color: var(--primary); 
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    
    .input-row {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    
    .input-row label {
        font-size: 0.9rem;
        color: var(--text-secondary);
        font-weight: 500;
    }
    
    .hint {
        margin: 0;
        font-size: 0.8rem;
        color: var(--text-muted);
    }
    
    .actions-row {
        display: flex;
        align-items: center;
        justify-content: center; /* Center actions */
        gap: 1rem;
        margin-top: 1rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(255,255,255,0.05);
    }
    
    .status-msg {
        font-size: 0.9rem;
        color: var(--text-secondary);
        opacity: 0;
        transition: opacity 0.3s ease;
    }
    
    .status-msg.success {
        color: var(--success);
        opacity: 1;
    }
    
    .justify-center {
        justify-content: center;
    }
</style>

@code {
    private string OutlookFolder { get; set; }
    // Kept for internal logic/preservation
    private string ScriptsPath { get; set; }
    private string ConsolidatedPath { get; set; }
    
    private string StatusMessage { get; set; }
    private bool IsSaved { get; set; }

    protected override void OnInitialized()
    {
        OutlookFolder = SettingsService.CurrentTargetFolder;
        ScriptsPath = SettingsService.ScriptsPath;
        ConsolidatedPath = SettingsService.ConsolidatedScriptsPath;
    }

    private async Task SaveSettings()
    {
        IsSaved = false;
        StatusMessage = "Saving...";
        StateHasChanged(); // Immediate feedback
        
        await SettingsService.UpdateSettingsAsync(OutlookFolder, ScriptsPath, ConsolidatedPath);
        
        IsSaved = true;
        StatusMessage = "Settings saved successfully!";
        Logger.LogSuccess("Settings updated by user.");
        
        // Hide message after delay
        await Task.Delay(2000);
        IsSaved = false;
        StatusMessage = "";
        StateHasChanged();
    }
}
