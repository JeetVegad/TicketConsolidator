@page "/settings"
@using TicketConsolidator.Infrastructure.Services
@using TicketConsolidator.Application.Interfaces
@inject SettingsService SettingsService
@inject ILoggerService Logger

<PageTitle>Settings | TicketConsolidator</PageTitle>

<div class="settings-container animate-fade-in custom-scroll">
    <div class="glass-panel content-card">
        <h2 class="page-title">Application Settings</h2>
        
        <div class="settings-grid">
            <!-- Left Col: Outlook -->
            <div class="settings-group">
                <h3 class="group-title">Outlook Integration</h3>
                <div class="input-row">
                    <label>Target Folder Name</label>
                    <input class="glass-input compact" @bind="OutlookFolder" placeholder="Inbox" />
                    <p class="hint">Folder to scan (e.g. 'Inbox').</p>
                </div>
            </div>

            <!-- Right Col: Paths -->
            <div class="settings-group">
                <h3 class="group-title">File Storage</h3>
                <div class="input-row">
                    <label>Scripts Path (Temp)</label>
                    <div class="path-input">
                        <input class="glass-input compact" @bind="ScriptsPath" />
                    </div>
                </div>
                
                <div class="input-row">
                    <label>Consolidated Output Path</label>
                    <div class="path-input">
                        <input class="glass-input compact" @bind="ConsolidatedPath" />
                    </div>
                </div>
            </div>
        </div>

        <div class="actions-row">
            <button class="glass-button compact-btn" @onclick="SaveSettings">
                <span class="btn-content">💾 Save Changes</span>
            </button>
            <span class="status-msg @(IsSaved ? "success" : "")">@StatusMessage</span>
        </div>
    </div>
</div>

<style>
    .settings-container {
        height: 100%;
        display: flex;
        align-items: center; /* Center vertically */
        justify-content: center;
        padding: 1rem;
        overflow: hidden; /* No scroll needed for single screen */
    }
    
    .content-card {
        width: 100%;
        max-width: 900px;
        padding: 1.5rem; /* Reduced from 2rem */
        display: flex;
        flex-direction: column;
        gap: 1.5rem; /* Reduced gap */
        background: #18181b; /* Solid zinc for contrast */
        border: 1px solid #27272a;
    }
    
    .page-title { 
        margin: 0; 
        font-size: 1.2rem; /* Smaller title */
        font-weight: 500; 
        color: var(--text-primary);
        border-bottom: 1px solid rgba(255,255,255,0.05);
        padding-bottom: 1rem;
    }
    
    .settings-grid {
        display: grid;
        grid-template-columns: 1fr 1fr; /* 2 Columns */
        gap: 2rem;
    }
    
    .settings-group {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    
    .group-title {
        margin: 0 0 0.5rem 0;
        font-size: 0.85rem;
        color: var(--primary);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    
    .input-row {
        display: flex;
        flex-direction: column;
        gap: 0.3rem; /* Tighter inputs */
    }
    
    .input-row label {
        font-size: 0.8rem;
        color: var(--text-secondary);
    }
    
    .compact {
        padding: 0.4rem 0.6rem; 
        font-size: 0.85rem;
        height: 32px;
    }
    
    .hint {
        margin: 0;
        font-size: 0.75rem;
        color: rgba(148, 163, 184, 0.5);
    }
    
    .actions-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-top: 0.5rem;
        padding-top: 1rem;
        border-top: 1px solid rgba(255,255,255,0.05);
    }
    
    .compact-btn {
        height: 36px;
        font-size: 0.9rem;
        padding: 0 1.2rem;
    }
    
    .status-msg {
        font-size: 0.85rem;
        color: var(--text-secondary);
        opacity: 0;
        transition: opacity 0.3s ease;
    }
    
    .status-msg.success {
        color: var(--success);
        opacity: 1;
    }
</style>

@code {
    private string OutlookFolder { get; set; }
    private string ScriptsPath { get; set; }
    private string ConsolidatedPath { get; set; }
    
    private string StatusMessage { get; set; }
    private bool IsSaved { get; set; }

    protected override void OnInitialized()
    {
        OutlookFolder = SettingsService.CurrentTargetFolder;
        ScriptsPath = SettingsService.ScriptsPath;
        ConsolidatedPath = SettingsService.ConsolidatedScriptsPath;
    }

    private async Task SaveSettings()
    {
        IsSaved = false;
        StatusMessage = "Saving...";
        StateHasChanged(); // Immediate feedback
        
        await SettingsService.UpdateSettingsAsync(OutlookFolder, ScriptsPath, ConsolidatedPath);
        
        IsSaved = true;
        StatusMessage = "Settings saved successfully!";
        Logger.LogSuccess("Settings updated by user.");
        
        // Hide message after delay
        await Task.Delay(2000);
        IsSaved = false;
        StatusMessage = "";
        StateHasChanged();
    }
}
