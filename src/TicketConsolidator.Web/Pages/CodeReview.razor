@page "/codereview"
@using TicketConsolidator.Application.Configurations
@using TicketConsolidator.Application.DTOs
@using TicketConsolidator.Application.Interfaces
@using TicketConsolidator.Infrastructure.Services
@inject IJiraService JiraService
@inject IPerforceService PerforceService
@inject IEmailService EmailService
@inject SettingsService SettingsService
@inject ILoggerService Logger
@inject Services.ToastService ToastService

<PageTitle>Code Review | TicketConsolidator</PageTitle>

<div class="page-container d-flex justify-center" style="padding-top: 3rem; padding-bottom: 4rem; align-items: flex-start;">
    <div class="glass-card cr-card animate-scale-in">
        <h2 class="page-title animate-fade-in delay-1">🔍 Code Review</h2>

        <!-- Search Bar -->
        <div class="cr-search animate-slide-up delay-2">
            <div class="search-row">
                <input class="glass-input cr-input" @bind="TicketKey" @bind:event="oninput"
                       @onkeydown="OnKeyDown" placeholder="Enter Jira Ticket (e.g., PROJ-1234)" />
                <button class="glass-button" @onclick="SearchTicket" disabled="@IsLoading">
                    <span class="btn-content">
                        @if (IsLoading)
                        {
                            <span class="spinner-inline"></span> <span>Searching...</span>
                        }
                        else
                        {
                            <span class="icon">🔎</span> <span>Search</span>
                        }
                    </span>
                </button>
            </div>

            <!-- Auth Status -->
            <div class="auth-status">
                @if (JiraService.IsAuthenticated)
                {
                    <span class="auth-badge connected">🟢 Connected to Jira</span>
                }
                else
                {
                    <span class="auth-badge disconnected">🔴 Not Connected</span>
                }
            </div>
        </div>

        <!-- Error Message -->
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="cr-error animate-fade-in">
                <span>⚠️ @ErrorMessage</span>
            </div>
        }

        <!-- Ticket Info Card -->
        @if (Ticket != null)
        {
            <div class="cr-section animate-slide-up delay-3">
                <h3 class="section-title">Ticket Details</h3>
                <div class="ticket-card">
                    <div class="ticket-header">
                        <a href="@Ticket.Url" target="_blank" class="ticket-key">@Ticket.Key</a>
                        <span class="ticket-status @GetStatusClass()">@Ticket.Status</span>
                    </div>
                    <h4 class="ticket-title">@Ticket.Summary</h4>
                    @if (!string.IsNullOrEmpty(Ticket.Description))
                    {
                        <p class="ticket-desc">@TruncateDescription(Ticket.Description)</p>
                    }
                    @if (!string.IsNullOrEmpty(Ticket.Assignee))
                    {
                        <div class="ticket-meta">
                            <span class="meta-label">Assignee:</span> <span>@Ticket.Assignee</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Changelists Section -->
            <div class="cr-section animate-slide-up delay-4">
                <h3 class="section-title">Perforce Changelists</h3>

                @if (Ticket.Changelists.Count == 0)
                {
                    <div class="empty-state">No changelists found for this ticket.</div>
                }
                else
                {
                    <!-- VS Commits -->
                    <div class="cl-group">
                        <h4 class="cl-group-title">💻 VS Commits</h4>
                        @if (Ticket.VSCommits.Count == 0)
                        {
                            <span class="cl-none">None found</span>
                        }
                        else
                        {
                            @foreach (var cl in Ticket.VSCommits)
                            {
                                <div class="cl-item @(SelectedVSCommit == cl ? "selected" : "")" @onclick="() => SelectVSCommit(cl)">
                                    <div class="cl-header">
                                        <span class="cl-number">@cl.ChangeNumber</span>
                                        <span class="cl-user">@cl.User</span>
                                        <span class="cl-date">@cl.Date.ToString("yyyy-MM-dd")</span>
                                    </div>
                                    <div class="cl-desc">@cl.Description</div>
                                    @if (cl.AffectedFiles.Count > 0)
                                    {
                                        <div class="cl-files">@cl.AffectedFiles.Count file(s)</div>
                                    }
                                </div>
                            }
                        }
                    </div>

                    <!-- DB Commits -->
                    <div class="cl-group">
                        <h4 class="cl-group-title">🗄️ DB Commits</h4>
                        @if (Ticket.DBCommits.Count == 0)
                        {
                            <span class="cl-none">None found</span>
                        }
                        else
                        {
                            @foreach (var cl in Ticket.DBCommits)
                            {
                                <div class="cl-item @(SelectedDBCommit == cl ? "selected" : "")" @onclick="() => SelectDBCommit(cl)">
                                    <div class="cl-header">
                                        <span class="cl-number">@cl.ChangeNumber</span>
                                        <span class="cl-user">@cl.User</span>
                                        <span class="cl-date">@cl.Date.ToString("yyyy-MM-dd")</span>
                                    </div>
                                    <div class="cl-desc">@cl.Description</div>
                                    @if (cl.AffectedFiles.Count > 0)
                                    {
                                        <div class="cl-files">@cl.AffectedFiles.Count file(s)</div>
                                    }
                                </div>
                            }
                        }
                    </div>
                }
            </div>

            <!-- Draft Email Button -->
            <div class="cr-actions animate-fade-in delay-5">
                <button class="glass-button" @onclick="DraftCodeReviewEmail" disabled="@IsLoading">
                    <span class="btn-content"><span class="icon">📧</span> Draft Code Review Email</span>
                </button>
            </div>
        }
    </div>
</div>

<style>
    .cr-card {
        width: 100%;
        max-width: 950px;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        padding: 2.5rem;
    }

    /* Search */
    .cr-search { display: flex; flex-direction: column; gap: 0.75rem; }
    .search-row { display: flex; gap: 0.75rem; align-items: center; }
    .cr-input { flex: 1; font-size: 1.05rem; }

    .auth-status { display: flex; align-items: center; }
    .auth-badge {
        font-size: 0.8rem;
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-weight: 600;
    }
    .auth-badge.connected { background: rgba(16,185,129,0.1); color: #6ee7b7; border: 1px solid rgba(16,185,129,0.2); }
    .auth-badge.disconnected { background: rgba(239,68,68,0.1); color: #fca5a5; border: 1px solid rgba(239,68,68,0.2); }

    .spinner-inline {
        display: inline-block;
        width: 14px; height: 14px;
        border: 2px solid rgba(255,255,255,0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.6s linear infinite;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }

    /* Error */
    .cr-error {
        background: rgba(239,68,68,0.1);
        border: 1px solid rgba(239,68,68,0.3);
        border-radius: var(--radius-sm);
        padding: 0.75rem 1rem;
        color: #fca5a5;
        font-size: 0.9rem;
    }

    /* Sections */
    .cr-section { display: flex; flex-direction: column; gap: 1rem; }
    .section-title {
        margin: 0;
        font-size: 0.8rem;
        color: var(--primary-light);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    /* Ticket Card */
    .ticket-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: var(--radius-sm);
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    .ticket-header { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
    .ticket-key {
        font-family: 'Consolas', monospace;
        font-weight: 700;
        color: var(--primary-light);
        text-decoration: none;
        font-size: 1.1rem;
    }
    .ticket-key:hover { text-decoration: underline; }
    .ticket-status {
        padding: 0.2rem 0.6rem;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
    }
    .ticket-status.status-open { background: rgba(59,130,246,0.15); color: #93c5fd; }
    .ticket-status.status-progress { background: rgba(251,191,36,0.15); color: #fcd34d; }
    .ticket-status.status-done { background: rgba(16,185,129,0.15); color: #6ee7b7; }
    .ticket-status.status-default { background: rgba(148,163,184,0.15); color: #94a3b8; }
    .ticket-title { margin: 0; font-size: 1.15rem; font-weight: 600; color: var(--text-primary); }
    .ticket-desc { margin: 0; font-size: 0.9rem; color: var(--text-secondary); line-height: 1.5; }
    .ticket-meta { font-size: 0.85rem; color: var(--text-muted); }
    .meta-label { font-weight: 600; color: var(--text-secondary); }

    /* Changelist Groups */
    .cl-group { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1rem; }
    .cl-group-title { margin: 0; font-size: 0.95rem; font-weight: 600; color: var(--text-primary); }
    .cl-none { font-size: 0.85rem; color: var(--text-muted); font-style: italic; }

    .cl-item {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: var(--radius-sm);
        padding: 0.75rem 1rem;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .cl-item:hover { border-color: rgba(255,255,255,0.15); background: rgba(255,255,255,0.05); }
    .cl-item.selected {
        border-color: var(--primary);
        background: rgba(var(--primary-rgb, 99,102,241), 0.08);
        box-shadow: 0 0 0 1px var(--primary);
    }
    .cl-header { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
    .cl-number {
        font-family: 'Consolas', monospace;
        font-weight: 700;
        color: var(--accent-light);
        font-size: 0.95rem;
    }
    .cl-user { font-size: 0.8rem; color: var(--text-secondary); }
    .cl-date { font-size: 0.8rem; color: var(--text-muted); margin-left: auto; }
    .cl-desc { font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.35rem; }
    .cl-files { font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem; }

    .empty-state {
        text-align: center;
        padding: 1.5rem;
        color: var(--text-muted);
        font-style: italic;
    }

    /* Actions */
    .cr-actions {
        display: flex;
        justify-content: center;
        padding-top: 0.5rem;
        border-top: 1px solid rgba(255,255,255,0.05);
    }
</style>

@code {
    private string TicketKey { get; set; } = "";
    private JiraTicketInfo Ticket { get; set; }
    private bool IsLoading { get; set; }
    private string ErrorMessage { get; set; }

    private PerforceChangelist SelectedVSCommit { get; set; }
    private PerforceChangelist SelectedDBCommit { get; set; }

    // Default Code Review Email Template
    private const string DefaultCodeReviewTemplate = @"<html>
<body style='font-family:Calibri,sans-serif;font-size:11pt'>
<p>Hi Team,</p>
<p>I've included the ticket's changeset details below for your review.</p>

<table border='1' cellpadding='6' cellspacing='0' style='border-collapse:collapse;font-family:Calibri;font-size:11pt'>
<tr style='background:#4472C4;color:white'>
  <th>Ticket</th><th>Change Set</th>
</tr>
<tr>
  <td>Ticket No:- <a href='{TicketUrl}'>{TicketKey} - {TicketTitle}</a></td>
  <td>&nbsp;</td>
</tr>
<tr>
  <td>&nbsp;</td>
  <td>VS Commit: <a href='{VSCommitUrl}'>{VSCommitNumber}</a></td>
</tr>
<tr>
  <td>&nbsp;</td>
  <td>DB Commit: <a href='{DBCommitUrl}'>{DBCommitNumber}</a></td>
</tr>
<tr>
  <td>Self-Code review Ticket No: NA</td>
  <td>&nbsp;</td>
</tr>
<tr>
  <td>&nbsp;</td>
  <td>VS Commit: NA</td>
</tr>
<tr>
  <td>&nbsp;</td>
  <td>DB Commit: NA</td>
</tr>
</table>

<br/>

<p><b>DB Review Checklist:-</b></p>
<table border='1' cellpadding='6' cellspacing='0' style='border-collapse:collapse;font-family:Calibri;font-size:11pt'>
<tr style='background:#4472C4;color:white'>
  <th>Sr. No.</th><th>Name</th><th>Is the point considered during development</th>
</tr>
<tr><td>1</td><td>I have used meaningful variable and method names.</td><td>Yes</td></tr>
<tr><td>2</td><td>I have enhanced the names of existing variables/methods based on a better understanding of the requirements.</td><td>NA</td></tr>
<tr><td>3</td><td>I am not adding any unnecessary extra files, code/commented code.</td><td>Yes</td></tr>
<tr><td>4</td><td>I am not committing any confidential information.</td><td>Yes</td></tr>
<tr><td>5</td><td>I have followed the ""single responsibility principle"".</td><td>NA</td></tr>
<tr><td>6</td><td>I have identified Unit Test Scenarios for the feature and at least documented them informally.</td><td>Yes</td></tr>
<tr><td>7</td><td>I have added meaningful logs for the new code. I have also added exception handling in the code.</td><td>NA</td></tr>
<tr><td>8</td><td>I have added the DB script of the config/data used. (Attach the DB script for data)</td><td>NA</td></tr>
<tr><td>9</td><td>Is the requirement/issue fully understood?</td><td>Yes</td></tr>
<tr><td>10</td><td>Is Self-code review done using Co-pilot?</td><td>NA</td></tr>
<tr><td>11</td><td>Has the co-pilot code review defect been raised?</td><td>NA</td></tr>
</table>

<br/>
<p>Best Regards,<br/>{UserName}</p>
</body>
</html>";

    private async Task OnKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchTicket();
    }

    private async Task SearchTicket()
    {
        if (string.IsNullOrWhiteSpace(TicketKey)) return;

        IsLoading = true;
        ErrorMessage = null;
        Ticket = null;
        SelectedVSCommit = null;
        SelectedDBCommit = null;
        StateHasChanged();

        try
        {
            // 1. Fetch from Jira (triggers Cisco OAuth popup if needed)
            Ticket = await JiraService.GetTicketAsync(TicketKey.Trim().ToUpperInvariant());

            // 2. Fetch Perforce changelists
            try
            {
                var changelists = await PerforceService.GetChangelistsByTicketAsync(TicketKey.Trim().ToUpperInvariant());
                Ticket.Changelists = changelists;
                Ticket.VSCommits = changelists.Where(c => !c.IsDatabase).ToList();
                Ticket.DBCommits = changelists.Where(c => c.IsDatabase).ToList();

                // Auto-select first of each if available
                SelectedVSCommit = Ticket.VSCommits.FirstOrDefault();
                SelectedDBCommit = Ticket.DBCommits.FirstOrDefault();
            }
            catch (Exception pex)
            {
                Logger.LogError($"Perforce fetch failed: {pex.Message}");
                ToastService.ShowError($"Perforce: {pex.Message}");
                // Non-blocking — ticket info still shown
            }

            ToastService.ShowSuccess($"Fetched ticket {Ticket.Key}");
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
            Logger.LogError($"Code Review search failed: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private async Task DraftCodeReviewEmail()
    {
        if (Ticket == null) return;

        IsLoading = true;
        StateHasChanged();

        try
        {
            string template = !string.IsNullOrEmpty(SettingsService.CodeReviewTemplate)
                ? SettingsService.CodeReviewTemplate
                : DefaultCodeReviewTemplate;

            string vsNum = SelectedVSCommit != null ? SelectedVSCommit.ChangeNumber.ToString() : "NA";
            string dbNum = SelectedDBCommit != null ? SelectedDBCommit.ChangeNumber.ToString() : "NA";
            string vsUrl = SelectedVSCommit != null ? $"#CL{SelectedVSCommit.ChangeNumber}" : "#";
            string dbUrl = SelectedDBCommit != null ? $"#CL{SelectedDBCommit.ChangeNumber}" : "#";

            string body = template
                .Replace("{TicketKey}", Ticket.Key)
                .Replace("{TicketTitle}", Ticket.Summary ?? "")
                .Replace("{TicketUrl}", Ticket.Url ?? "")
                .Replace("{TicketDescription}", Ticket.Description ?? "")
                .Replace("{TicketStatus}", Ticket.Status ?? "")
                .Replace("{Assignee}", Ticket.Assignee ?? "")
                .Replace("{VSCommitNumber}", vsNum)
                .Replace("{VSCommitUrl}", vsUrl)
                .Replace("{DBCommitNumber}", dbNum)
                .Replace("{DBCommitUrl}", dbUrl)
                .Replace("{UserName}", Environment.UserName)
                .Replace("{Date}", DateTime.Now.ToString("yyyy-MM-dd"));

            string subject = $"Code Review - {Ticket.Key} - {Ticket.Summary}";
            await EmailService.CreateDraftEmailAsync(subject, body, null);

            ToastService.ShowSuccess("Code Review email draft created in Outlook!");
            Logger.LogSuccess($"Code Review email drafted for {Ticket.Key}");
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Email draft failed: {ex.Message}";
            Logger.LogError($"Code Review email failed: {ex.Message}");
            ToastService.ShowError(ex.Message);
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private void SelectVSCommit(PerforceChangelist cl) => SelectedVSCommit = cl;
    private void SelectDBCommit(PerforceChangelist cl) => SelectedDBCommit = cl;

    private string TruncateDescription(string desc)
    {
        if (string.IsNullOrEmpty(desc)) return "";
        return desc.Length > 300 ? desc.Substring(0, 300) + "..." : desc;
    }

    private string GetStatusClass()
    {
        if (Ticket?.Status == null) return "status-default";
        var lower = Ticket.Status.ToLowerInvariant();
        if (lower.Contains("done") || lower.Contains("closed") || lower.Contains("resolved")) return "status-done";
        if (lower.Contains("progress") || lower.Contains("review")) return "status-progress";
        if (lower.Contains("open") || lower.Contains("to do") || lower.Contains("new")) return "status-open";
        return "status-default";
    }
}
