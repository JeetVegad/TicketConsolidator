@page "/logs"
@using TicketConsolidator.Infrastructure.Services
@using TicketConsolidator.Application.DTOs
@using TicketConsolidator.Application.Interfaces
@using System.Collections.Specialized
@inject ILoggerService LoggerService
@implements IDisposable

<PageTitle>Logs | TicketConsolidator</PageTitle>

<div class="logs-page-container animate-fade-in">
    <header class="logs-header glass-panel">
        <h2 class="page-title">Application Logs</h2>
        <div class="header-actions">
            <button class="glass-button-secondary small" @onclick="LoadHistory">
                <span class="btn-content">📜 Load History</span>
            </button>
            <button class="glass-button-secondary small" @onclick="RefreshLogs">
                 <span class="btn-content">🔄 Refresh</span>
            </button>
        </div>
    </header>

    <div class="logs-content custom-scroll">
        @if (Sessions.Count == 0)
        {
            <div class="empty-state">
                <span class="icon">📝</span>
                <p>No active logging sessions.</p>
            </div>
        }
        else
        {
            <div class="session-list">
                @foreach(var session in Sessions)
                {
                    <div class="log-session glass-card">
                         <div class="session-header @(session.IsExpanded ? "expanded" : "")" @onclick="() => ToggleSession(session)">
                             <div class="session-info">
                                 <span class="toggle-icon">@(session.IsExpanded ? "▼" : "▶")</span>
                                 <span class="session-name">@session.SessionName</span>
                                 <span class="badge">@session.Logs.Count</span>
                             </div>
                             <span class="session-time">Last update: @DateTime.Now.ToString("HH:mm")</span>
                         </div>
                         
                         @if(session.IsExpanded)
                         {
                             <div class="log-entries">
                                 @if (session.Logs.Count == 0)
                                 {
                                     <div class="no-entries">No entries in this session.</div>
                                 }
                                 else
                                 {
                                     @foreach(var entry in session.Logs)
                                     {
                                         <div class="log-row @GetLevelClass(entry.Level)">
                                             <span class="log-time">@entry.Timestamp.ToString("HH:mm:ss.fff")</span>
                                             <span class="log-level">@entry.Level</span>
                                             <span class="log-msg">@entry.Message</span>
                                         </div>
                                     }
                                 }
                             </div>
                         }
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    .logs-page-container {
        display: flex;
        flex-direction: column;
        height: 100%;
        overflow: hidden;
        padding: 1.5rem;
        gap: 1.5rem;
    }

    .logs-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 1.5rem;
        border-radius: var(--radius-lg);
    }
    
    .page-title {
        margin: 0;
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--text-primary);
    }

    .header-actions { display: flex; gap: 0.8rem; }
    .small { padding: 0.4rem 0.8rem; font-size: 0.85rem; height: auto; }

    .logs-content {
        flex: 1;
        overflow-y: auto;
        padding-right: 0.5rem; 
    }

    .log-session {
        margin-bottom: 1rem;
        overflow: hidden;
        transition: all 0.2s;
        border: 1px solid rgba(255,255,255,0.05);
    }

    .session-header {
        padding: 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
        background: rgba(255,255,255,0.02);
        transition: background 0.2s;
    }

    .session-header:hover { background: rgba(255,255,255,0.05); }
    .session-header.expanded { background: rgba(255,255,255,0.04); border-bottom: 1px solid rgba(255,255,255,0.05); }

    .session-info { display: flex; align-items: center; gap: 0.8rem; }
    
    .toggle-icon { font-size: 0.8rem; color: var(--text-tertiary); width: 16px; display: inline-block; text-align: center; }
    .session-name { font-weight: 600; color: var(--text-secondary); font-size: 0.95rem; }
    
    .badge {
        background: rgba(255,255,255,0.1);
        color: var(--text-tertiary);
        font-size: 0.75rem;
        padding: 0.1rem 0.5rem;
        border-radius: 12px;
    }
    
    .session-time { font-size: 0.8rem; color: var(--text-tertiary); opacity: 0.6; }

    .log-entries {
        background: rgba(0,0,0,0.3);
        padding: 0.5rem 0;
        max-height: 400px;
        overflow-y: auto;
    }

    .no-entries { padding: 1rem; color: var(--text-tertiary); font-style: italic; text-align: center; }

    .log-row {
        display: grid;
        grid-template-columns: 100px 90px 1fr;
        gap: 1rem;
        padding: 0.35rem 1rem;
        font-family: 'JetBrains Mono', 'Consolas', monospace;
        font-size: 0.85rem;
        border-bottom: 1px solid rgba(255,255,255,0.02);
        transition: background 0.1s;
    }
    
    .log-row:hover { background: rgba(255,255,255,0.03); }

    .log-time { color: var(--text-tertiary); opacity: 0.6; font-size: 0.8rem; }
    
    .log-level { 
        font-weight: 700; 
        font-size: 0.75rem; 
        text-transform: uppercase; 
        letter-spacing: 0.05em;
    }
    
    .log-msg { color: var(--text-secondary); white-space: pre-wrap; word-break: break-word; line-height: 1.5; }

    /* Level Colors */
    .log-row.info .log-level { color: #94a3b8; }
    .log-row.warning .log-level { color: #fbbf24; }
    .log-row.error .log-level { color: #f87171; }
    .log-row.success .log-level { color: #34d399; }
    
    .log-row.error .log-msg { color: #fca5a5; }

    .empty-state {
        display: flex; 
        flex-direction: column; 
        align-items: center; 
        justify-content: center; 
        height: 100%; 
        color: var(--text-secondary); 
        gap: 1rem;
        opacity: 0.5;
    }
    .empty-state .icon { font-size: 3rem; }
</style>

@code {
    private List<LogSession> Sessions = new List<LogSession>();
    private System.Timers.Timer _timer;

    protected override async Task OnInitializedAsync()
    {
        if (LoggerService is LoggerService service)
        {
            UpdateSessions();
        }
        
        // Initial Fetch from DB
        await LoadHistory();
        
        // Polling for live updates
        _timer = new System.Timers.Timer(1000);
        _timer.Elapsed += (s, e) => InvokeAsync(() => {
             UpdateSessions();
             StateHasChanged();
        });
        _timer.AutoReset = true;
        _timer.Start();
    }

    private void UpdateSessions()
    {
         if (LoggerService is LoggerService service)
         {
             // Create a shallow copy to avoid collection modification errors during enumeration
             var currentSessions = service.Sessions.ToList();
             
             // Only update if count changed to avoid re-rendering entire tree unnecessarily (basic optimization)
             // For deep log changes, the timer will force StateHasChanged anyway.
             Sessions = currentSessions;
         }
    }

    private void RefreshLogs()
    {
        UpdateSessions();
        StateHasChanged();
    }
    
    private async Task LoadHistory()
    {
         await LoggerService.LoadHistoryAsync();
         UpdateSessions();
    }

    private void ToggleSession(LogSession session)
    {
        session.IsExpanded = !session.IsExpanded;
    }
    
    public void Dispose()
    {
        _timer?.Dispose();
    }

    private string GetLevelClass(LogLevel level)
    {
        return level switch
        {
            LogLevel.Warning => "warning",
            LogLevel.Error => "error",
            LogLevel.Success => "success",
            _ => "info"
        };
    }
}
