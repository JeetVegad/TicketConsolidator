@page "/logs"
@using TicketConsolidator.Infrastructure.Services
@using TicketConsolidator.Application.DTOs
@using TicketConsolidator.Application.Interfaces
@inject ILoggerService LoggerService
@implements IDisposable

<PageTitle>Logs | TicketConsolidator</PageTitle>

<div class="logs-container animate-fade-in">
    <div class="glass-panel content-card full-height">
        <div class="logs-header">
            <h2 class="page-title">Application Logs</h2>
            <button class="glass-button-secondary small" @onclick="RefreshLogs">
                <span class="btn-content">🔄 Refresh</span>
            </button>
        </div>
        
        <div class="logs-viewport custom-scroll">
            @if (Sessions.Count == 0)
            {
                <div class="empty-logs">No logs available.</div>
            }
            else
            {
                <div class="session-list">
                    @foreach(var session in Sessions)
                    {
                        <div class="log-session">
                             <div class="session-header @(session.IsExpanded ? "active" : "")" @onclick="() => ToggleSession(session)">
                                 <span class="toggle-icon">@(session.IsExpanded ? "▼" : "▶")</span>
                                 <span class="session-title">@session.SessionName</span>
                                 <span class="log-count">(@session.Logs.Count)</span>
                             </div>
                             
                             @if(session.IsExpanded)
                             {
                                 <div class="log-entries animate-slide-up">
                                     @foreach(var entry in session.Logs)
                                     {
                                         <div class="log-row @entry.Level.ToString().ToLower()">
                                             <span class="log-time">@entry.Timestamp.ToString("HH:mm:ss")</span>
                                             <span class="log-level">@entry.Level</span>
                                             <span class="log-msg">@entry.Message</span>
                                         </div>
                                     }
                                 </div>
                             }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<style>
    .logs-container {
        height: 100%;
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
    }
    
    .content-card.full-height {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        padding: 0;
    }

    .logs-header {
        padding: 1.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: rgba(0,0,0,0.2);
    }
    
    .logs-viewport {
        flex: 1;
        overflow-y: auto;
        padding: 1rem;
    }
    
    .log-session {
        margin-bottom: 0.5rem;
        background: rgba(255,255,255,0.02);
        border-radius: var(--radius-sm);
        border: 1px solid rgba(255,255,255,0.05);
    }
    
    .session-header {
        padding: 0.75rem 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 500;
        color: var(--text-secondary);
        transition: all 0.2s;
    }
    
    .session-header:hover { background: rgba(255,255,255,0.05); color: var(--text-primary); }
    .session-header.active { background: rgba(255,255,255,0.05); border-bottom: 1px solid rgba(255,255,255,0.05); color: var(--primary); }
    
    .log-count { font-size: 0.8rem; opacity: 0.5; }
    
    .log-entries {
        padding: 0.5rem 0;
        background: rgba(0,0,0,0.2);
    }
    
    .log-row {
        display: grid;
        grid-template-columns: 80px 70px 1fr;
        gap: 1rem;
        padding: 0.25rem 1rem;
        font-family: 'Consolas', monospace;
        font-size: 0.85rem;
        border-bottom: 1px solid rgba(255,255,255,0.02);
    }
    
    .log-row:last-child { border-bottom: none; }
    
    .log-time { color: var(--text-secondary); opacity: 0.7; }
    .log-level { font-weight: 600; text-transform: uppercase; font-size: 0.75rem; padding-top: 1px; }
    .log-msg { color: var(--text-primary); white-space: pre-wrap; word-break: break-word; }

    /* Colors */
    .log-row.info .log-level { color: #cbd5e1; } /* Brighter Slate */
    .log-row.warning .log-level { color: #fcd34d; text-shadow: 0 0 5px rgba(251, 191, 36, 0.4); } /* Amber Glow */
    .log-row.error .log-level { color: #f87171; text-shadow: 0 0 5px rgba(248, 113, 113, 0.4); } /* Red Glow */
    .log-row.success .log-level { color: #4ade80; text-shadow: 0 0 5px rgba(74, 222, 128, 0.4); } /* Green Glow */
    
    .small { padding: 0.4rem 1rem; font-size: 0.85rem; }
    
    .empty-logs { padding: 2rem; text-align: center; color: var(--text-secondary); }
</style>

@code {
    private List<LogSession> Sessions => (LoggerService as LoggerService)?.Sessions.ToList() ?? new List<LogSession>();
    private System.Timers.Timer _timer;

    protected override void OnInitialized()
    {
        // Auto-refresh logs every 1s to keep UI updated
        _timer = new System.Timers.Timer(1000);
        _timer.Elapsed += (s, e) => InvokeAsync(StateHasChanged);
        _timer.AutoReset = true;
        _timer.Start();
    }

    private void RefreshLogs()
    {
        StateHasChanged();
    }

    private void ToggleSession(LogSession session)
    {
        session.IsExpanded = !session.IsExpanded;
    }
    
    public void Dispose()
    {
        _timer?.Dispose();
    }
}
