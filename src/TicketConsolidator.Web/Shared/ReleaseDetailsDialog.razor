@namespace TicketConsolidator.Web.Components

@if(IsVisible)
{
    <div class="dialog-overlay animate-fade-in" @onclick="Cancel">
        <div class="dialog-card animate-scale-in" @onclick:stopPropagation="true">
            <div class="dialog-header">
                <h3 class="dialog-title">Release Details</h3>
                <button class="close-btn" @onclick="Cancel" title="Close">✕</button>
            </div>
            
            <div class="dialog-body">
                <div class="form-group">
                    <label class="input-label">Build Number</label>
                    <input class="glass-input" @bind="BuildNumber" placeholder="e.g. 10.0.123" />
                </div>

                <div class="form-group">
                    <label class="input-label">Solution Path</label>
                    <input class="glass-input" @bind="SolutionPath" placeholder="\\Network\Share\Release" />
                </div>
                
                <div class="form-group">
                    <label class="input-label">Your Name</label>
                    <input class="glass-input" @bind="Username" placeholder="John Doe" />
                </div>
            </div>
            
            <div class="dialog-footer">
                <button class="glass-button-secondary" @onclick="Cancel">Cancel</button>
                <button class="glass-button" @onclick="Confirm">
                    <span class="btn-icon">📧</span> Create Draft
                </button>
            </div>
        </div>
    </div>
}

<style>
    .dialog-overlay {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0, 0, 0, 0.75); /* Darker backdrop */
        backdrop-filter: blur(4px);
        z-index: 2000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

    .dialog-card {
        width: 100%;
        max-width: 440px;
        background: #18181b; /* Zinc 900 - Solid */
        border: 1px solid #3f3f46; /* Zinc 700 */
        border-radius: var(--radius-lg);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5); /* Deep shadow */
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .dialog-header {
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid #27272a;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #18181b;
    }

    .dialog-title {
        margin: 0;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text-primary);
    }

    .close-btn {
        background: none; 
        border: none; 
        color: var(--text-tertiary);
        font-size: 1.1rem; 
        cursor: pointer;
        padding: 4px;
        border-radius: 4px;
        line-height: 1;
        transition: color 0.2s;
    }
    .close-btn:hover { color: var(--text-primary); }
    
    .dialog-body {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        background: #18181b;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .input-label {
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--text-secondary);
    }

    .dialog-footer {
        padding: 1.25rem 1.5rem;
        display: flex;
        justify-content: flex-end;
        gap: 0.75rem;
        border-top: 1px solid #27272a;
        background: #27272a; /* Slightly lighter footer */
    }

    /* Simple Animations */
    .animate-fade-in { animation: fadeIn 0.2s ease-out; }
    .animate-scale-in { animation: scaleIn 0.25s cubic-bezier(0.16, 1, 0.3, 1); }

    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes scaleIn {
        from { opacity: 0; transform: scale(0.95) translateY(10px); }
        to { opacity: 1; transform: scale(1) translateY(0); }
    }
    
    /* .loader-mini removed - uses global theme.css */
</style>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    
    [Parameter] public EventCallback OnSubmit { get; set; }

    public string BuildNumber { get; set; }
    public string SolutionPath { get; set; }
    public string Username { get; set; } = System.Environment.UserName;
    
    private bool IsProcessing { get; set; }

    public void SetDefaults(string build, string path)
    {
        BuildNumber = build;
        SolutionPath = path;
    }

    private async Task Confirm()
    {
        if (IsProcessing) return;
        
        IsProcessing = true;
        IsProcessing = true;
        StateHasChanged(); 
        // Instant feedback requested - no delay
        
        try
        {
            await OnSubmit.InvokeAsync();
            await Close();
        }
        finally
        {
            IsProcessing = false;
        }
    }

    private async Task Cancel()
    {
        await Close();
    }
    
    private async Task Close()
    {
        IsVisible = false;
        await IsVisibleChanged.InvokeAsync(false);
    }
}
