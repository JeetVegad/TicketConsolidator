@namespace TicketConsolidator.Web.Components

<dialog id="releaseDialog" class="glass-panel dialog-modal" open="@IsVisible">
    <div class="dialog-header">
        <h3>Release Details</h3>
        <button class="close-btn" @onclick="Cancel">✕</button>
    </div>
    
    <div class="dialog-body">
        <label class="input-label">Build Number</label>
        <input class="glass-input" @bind="BuildNumber" placeholder="e.g. 10.0.123" />
        
        <label class="input-label">Solution Path</label>
        <input class="glass-input" @bind="SolutionPath" placeholder="\\Network\Share\Release" />
        
        <label class="input-label">Your Name</label>
        <input class="glass-input" @bind="Username" placeholder="John Doe" />
    </div>
    
    <div class="dialog-footer">
        <button class="glass-button-secondary" @onclick="Cancel">Cancel</button>
        <button class="glass-button" @onclick="Confirm">Create Email</button>
    </div>
</dialog>

@if(IsVisible)
{
    <div class="backdrop animate-fade-in"></div>
}

<style>
    .dialog-modal {
        position: fixed;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        z-index: 2000;
        padding: 0;
        border: 1px solid rgba(255,255,255,0.1);
        width: 400px;
        color: var(--text-primary);
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        display: none;
    }
    
    .dialog-modal[open] {
        display: block;
        animation: slideUp 0.3s ease-out;
    }

    .backdrop {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.6);
        backdrop-filter: blur(2px);
        z-index: 1500;
    }

    .dialog-header {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .dialog-header h3 { margin: 0; font-size: 1.1rem; }

    .close-btn {
        background: none; border: none; color: var(--text-secondary);
        font-size: 1.2rem; cursor: pointer;
    }
    
    .dialog-body {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .input-label {
        font-size: 0.9rem;
        color: var(--text-secondary);
        margin-bottom: -0.5rem;
    }

    .dialog-footer {
        padding: 1rem 1.5rem;
        display: flex;
        justify-content: flex-end;
        gap: 1rem;
        border-top: 1px solid rgba(255,255,255,0.1);
        background: rgba(0,0,0,0.1);
    }
</style>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    
    [Parameter] public EventCallback OnSubmit { get; set; }

    public string BuildNumber { get; set; }
    public string SolutionPath { get; set; }
    public string Username { get; set; } = Environment.UserName;

    // Method to allow parent to set defaults
    public void SetDefaults(string build, string path)
    {
        BuildNumber = build;
        SolutionPath = path;
    }

    private async Task Confirm()
    {
        await OnSubmit.InvokeAsync();
        await Close();
    }

    private async Task Cancel()
    {
        await Close();
    }
    
    private async Task Close()
    {
        IsVisible = false;
        await IsVisibleChanged.InvokeAsync(false);
    }
}
