@inherits LayoutComponentBase

<div class="app-layout">
    <header class="app-header glass-panel">
        <div class="brand animate-fade-in delay-1">
            <span class="brand-icon live-icon">✨</span>
            <span class="brand-text">TicketConsolidator</span>
        </div>
        <nav class="top-nav animate-fade-in delay-2">
            <NavLink href="" Match="NavLinkMatch.All" class="nav-link">
                <span class="icon">📊</span> Dashboard
            </NavLink>
            <NavLink href="settings" class="nav-link">
                <span class="icon">⚙️</span> Settings
            </NavLink>
            <NavLink href="logs" class="nav-link">
                <span class="icon">📝</span> Logs
            </NavLink>
            <NavLink href="help" class="nav-link">
                <span class="icon">❓</span> Help
            </NavLink>
        </nav>
    </header>

    <main class="content-container custom-scroll">
        <div class="page-transition-wrapper">
            @Body
        </div>
    </main>
    
    <ToastContainer />
</div>

<style>
    .app-layout {
        display: flex;
        flex-direction: column;
        height: 100vh;
        overflow: hidden;
        position: relative;
        background-color: var(--bg-app);
    }
    
    .app-header {
        position: relative;
        z-index: 100; /* Increased z-index for safety */
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 1.5rem;
        height: var(--header-height);
        flex-shrink: 0;
        /* Background handled by .glass-panel */
    }

    .brand {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-size: 1.1rem;
        font-weight: 700;
        color: white;
        letter-spacing: 0.02em;
        text-shadow: 0 0 20px rgba(255,255,255,0.3);
    }
    
    .top-nav { display: flex; gap: 0.5rem; }

    .nav-link {
        color: rgba(255,255,255,0.6);
        text-decoration: none;
        padding: 0.4rem 0.8rem;
        border-radius: var(--radius-sm); /* Use variable */
        transition: all 0.3s;
        font-size: 0.85rem;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .nav-link:hover {
        color: white;
        background: rgba(255, 255, 255, 0.1);
        transform: translateY(-1px);
    }

    .nav-link.active {
        color: white;
        background: linear-gradient(135deg, rgba(255,255,255,0.1), rgba(255,255,255,0.05));
        border: 1px solid rgba(255,255,255,0.1);
        box-shadow: 0 0 15px rgba(255,255,255,0.1);
    }

    .content-container {
        flex: 1;
        overflow: hidden;
        position: relative;
        z-index: 1;
    }
    
    /* Ensure page transitions work smoothly with new animations */
    .page-transition-wrapper {
        height: 100%; /* Fixed height to force scroll container */
        width: 100%;
        position: relative;
        overflow: hidden;
    }
</style>
