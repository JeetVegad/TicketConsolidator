<UserControl x:Class="TicketConsolidator.UI.Views.CodeReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="MainPanel" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.15"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
            <StackPanel x:Name="MainPanel">
                <!-- Page Title -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <materialDesign:PackIcon Kind="FileDocumentEdit" Width="28" Height="28" 
                                             VerticalAlignment="Center" Margin="0,0,10,0"
                                             Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                    <TextBlock Text="Code Review" Style="{StaticResource MaterialDesignHeadline5TextBlock}" 
                               Foreground="{DynamicResource MaterialDesignBody}"/>
                </StackPanel>

                <!-- Jira Login Card -->
                <materialDesign:Card Padding="20" UniformCornerRadius="8" 
                                     materialDesign:ShadowAssist.ShadowDepth="Depth2" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Status icon -->
                        <materialDesign:PackIcon VerticalAlignment="Center" Width="24" Height="24" Margin="0,0,12,0">
                            <materialDesign:PackIcon.Style>
                                <Style TargetType="materialDesign:PackIcon">
                                    <Setter Property="Kind" Value="ShieldAlertOutline"/>
                                    <Setter Property="Foreground" Value="#FF9800"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                                            <Setter Property="Kind" Value="ShieldCheckOutline"/>
                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </materialDesign:PackIcon.Style>
                        </materialDesign:PackIcon>

                        <!-- Status text -->
                        <TextBlock Grid.Column="1" Text="{Binding AuthStatus}" VerticalAlignment="Center" FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#757575"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Login button -->
                        <Button Grid.Column="2" Command="{Binding LoginCommand}" 
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                ToolTip="Open Jira login window"
                                materialDesign:ButtonAssist.CornerRadius="6">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Login" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="LOGIN TO JIRA" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </materialDesign:Card>

                <!-- Search Card -->
                <materialDesign:Card Padding="20" UniformCornerRadius="8" 
                                     materialDesign:ShadowAssist.ShadowDepth="Depth2" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Search Ticket" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                                   FontWeight="SemiBold" Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Ticket Key Input -->
                            <TextBox Text="{Binding TicketKey, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Enter Jira Ticket (e.g., PROJ-1234)"
                                     materialDesign:HintAssist.IsFloating="True"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     FontSize="14" Margin="0,0,10,0"
                                     KeyDown="SearchBox_KeyDown"/>

                            <Button Grid.Column="1" Command="{Binding SearchCommand}" 
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    ToolTip="Search Jira Ticket">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Magnify" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="SEARCH" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Loading Indicator -->
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0"
                                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                         IsIndeterminate="True" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding StatusMessage}" Opacity="0.7" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Status / Error -->
                        <TextBlock Text="{Binding StatusMessage}" Margin="0,10,0,0" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasError}" Value="True">
                                            <Setter Property="Foreground" Value="#F44336"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasTicket}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasError}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Ticket Details Card -->
                <materialDesign:Card Padding="20" UniformCornerRadius="8" 
                                     materialDesign:ShadowAssist.ShadowDepth="Depth2" Margin="0,0,0,15"
                                     Visibility="{Binding HasTicket, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="Ticket Details" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                                   FontWeight="SemiBold" Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Background="{DynamicResource PrimaryHueMidBrush}" CornerRadius="4" 
                                    Padding="10,5" VerticalAlignment="Top" Margin="0,0,15,0">
                                <TextBlock Text="{Binding Ticket.Key}" Foreground="White" 
                                           FontWeight="Bold" FontSize="14" FontFamily="Consolas"/>
                            </Border>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding Ticket.Summary}" FontSize="16" FontWeight="SemiBold"
                                           TextWrapping="Wrap" Margin="0,0,0,5"/>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <materialDesign:PackIcon Kind="AccountCircle" Width="16" Height="16" 
                                                             VerticalAlignment="Center" Margin="0,0,5,0" Opacity="0.6"/>
                                    <TextBlock Text="{Binding Ticket.Assignee}" Opacity="0.7" VerticalAlignment="Center"/>
                                    
                                    <Border Background="#E3F2FD" CornerRadius="10" Padding="8,3" Margin="15,0,0,0">
                                        <TextBlock Text="{Binding Ticket.Status}" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="#1565C0"/>
                                    </Border>
                                </StackPanel>

                                <TextBlock Text="{Binding Ticket.Description}" TextWrapping="Wrap" 
                                           MaxHeight="60" TextTrimming="CharacterEllipsis"
                                           Opacity="0.6" FontSize="12" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Found Links Card (assign to VS or DB) -->
                <materialDesign:Card Padding="20" UniformCornerRadius="8" 
                                     materialDesign:ShadowAssist.ShadowDepth="Depth2" Margin="0,0,0,15"
                                     Visibility="{Binding HasFoundLinks, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="Linked Commits — Assign to VS or DB" 
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                                   FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBlock Text="Click the buttons to assign each commit to VS Commits or DB Commits"
                                   FontSize="12" Opacity="0.6" Margin="0,0,0,15"/>

                        <!-- Target Ticket Selection -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Assigning to:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold" FontSize="13"/>
                            <ComboBox ItemsSource="{Binding TargetTickets}" 
                                      SelectedItem="{Binding SelectedTargetTicket}" 
                                      DisplayMemberPath="DisplayName" 
                                      Width="350" 
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding FoundLinks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FAFAFA" CornerRadius="6" Padding="12,10" Margin="0,0,0,8"
                                            BorderBrush="#E0E0E0" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel VerticalAlignment="Center" Margin="0,0,10,0">
                                                <TextBlock Text="{Binding DisplayText}" FontWeight="SemiBold" FontSize="13"
                                                           TextWrapping="Wrap" Margin="0,0,0,2"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                    <TextBlock Text="{Binding Relationship}" FontSize="11" Opacity="0.5" 
                                                               Margin="0,0,10,0"/>
                                                    <TextBlock Text="{Binding ChangeNumber, StringFormat='CL #{0}'}" 
                                                               FontSize="11" FontFamily="Consolas" Opacity="0.7" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <Button Grid.Column="1"
                                                    Command="{Binding DataContext.AssignVSCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    Foreground="#2196F3" BorderBrush="#2196F3"
                                                    Padding="10,4" Margin="8,0,0,0" Height="32"
                                                    ToolTip="Assign as VS Commit">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="CodeBraces" Width="16" Height="16" Margin="0,0,4,0"/>
                                                    <TextBlock Text="VS" FontWeight="Bold" FontSize="11"/>
                                                </StackPanel>
                                            </Button>

                                            <Button Grid.Column="2"
                                                    Command="{Binding DataContext.AssignDBCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    Foreground="#FF9800" BorderBrush="#FF9800"
                                                    Padding="10,4" Margin="8,0,0,0" Height="32"
                                                    ToolTip="Assign as DB Commit">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Database" Width="16" Height="16" Margin="0,0,4,0"/>
                                                    <TextBlock Text="DB" FontWeight="Bold" FontSize="11"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Assigned Commits Card -->
                <materialDesign:Card Padding="20" UniformCornerRadius="8" 
                                     materialDesign:ShadowAssist.ShadowDepth="Depth2" Margin="0,0,0,15"
                                     Visibility="{Binding HasTicket, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- VS Commits -->
                        <StackPanel Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <materialDesign:PackIcon Kind="CodeBraces" Width="20" Height="20" 
                                                         Foreground="#2196F3" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="VS Commits" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>

                            <ItemsControl ItemsSource="{Binding VSCommits}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#E3F2FD" CornerRadius="4" Padding="10,6" Margin="0,0,0,5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Margin="0,0,10,0">
                                                    <TextBlock Text="{Binding AssignedTicketKey}" FontSize="11" FontWeight="Bold" Foreground="#1976D2" Margin="0,0,0,2"/>
                                                    <TextBlock Text="{Binding DisplayText}" FontSize="12" FontWeight="SemiBold"
                                                               TextWrapping="Wrap" Margin="0,0,0,2"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" 
                                                        Command="{Binding DataContext.RemoveVSCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource MaterialDesignFlatButton}"
                                                        Padding="4" ToolTip="Remove" Width="28" Height="28">
                                                    <materialDesign:PackIcon Kind="Close" Width="14" Height="14" Foreground="#F44336"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="No VS commits assigned" FontStyle="Italic" Opacity="0.4" FontSize="12"
                                       Margin="0,5,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding VSCommits.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- DB Commits -->
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <materialDesign:PackIcon Kind="Database" Width="20" Height="20" 
                                                         Foreground="#FF9800" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="DB Commits" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>

                            <ItemsControl ItemsSource="{Binding DBCommits}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FFF3E0" CornerRadius="4" Padding="10,6" Margin="0,0,0,5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Margin="0,0,10,0">
                                                    <TextBlock Text="{Binding AssignedTicketKey}" FontSize="11" FontWeight="Bold" Foreground="#E65100" Margin="0,0,0,2"/>
                                                    <TextBlock Text="{Binding DisplayText}" FontSize="12" FontWeight="SemiBold"
                                                               TextWrapping="Wrap" Margin="0,0,0,2"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" 
                                                        Command="{Binding DataContext.RemoveDBCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource MaterialDesignFlatButton}"
                                                        Padding="4" ToolTip="Remove" Width="28" Height="28">
                                                    <materialDesign:PackIcon Kind="Close" Width="14" Height="14" Foreground="#F44336"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="No DB commits assigned" FontStyle="Italic" Opacity="0.4" FontSize="12"
                                       Margin="0,5,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DBCommits.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>

                <!-- Draft Email Button -->
                <Button Command="{Binding DraftEmailCommand}" HorizontalAlignment="Left"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Visibility="{Binding HasTicket, Converter={StaticResource BoolToVis}}"
                        ToolTip="Create Code Review email draft in Outlook"
                        Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="EmailEdit" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="DRAFT CODE REVIEW EMAIL" VerticalAlignment="Center" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
