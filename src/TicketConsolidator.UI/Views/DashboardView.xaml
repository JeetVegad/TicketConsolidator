<UserControl x:Class="TicketConsolidator.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:TicketConsolidator.UI.Helpers"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             TextElement.FontWeight="Regular"
             TextElement.FontSize="13"
             TextOptions.TextFormattingMode="Ideal"
             TextOptions.TextRenderingMode="Auto"
             Background="#F5F5F5"
             FontFamily="{DynamicResource MaterialDesignFont}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <helpers:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <helpers:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        
        <!-- Fluid Items Panel for Sliding Animation -->
        <ItemsPanelTemplate x:Key="FluidItemsPanel">
            <StackPanel>
                <b:Interaction.Behaviors>
                    <b:FluidMoveBehavior AppliesTo="Children" Duration="0:0:0.25">
                        <b:FluidMoveBehavior.EaseY>
                            <QuadraticEase EasingMode="EaseInOut"/>
                        </b:FluidMoveBehavior.EaseY>
                    </b:FluidMoveBehavior>
                </b:Interaction.Behaviors>
            </StackPanel>
        </ItemsPanelTemplate>

        <!-- Simplified List Item Style with Hover Animation -->
        
        <!-- Simplified List Item Style with Hover Animation -->
        <Style x:Key="CardHoverStyle" TargetType="materialDesign:Card">
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="materialDesign:ShadowAssist.ShadowDepth" Value="Depth1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="materialDesign:ShadowAssist.ShadowDepth" Value="Depth2"/>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.02" ScaleY="1.02" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Slide In Animation for New Items -->
        <Style x:Key="SlideInAnimation" TargetType="ContentPresenter">
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
                            <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,20,0,0" To="0,0,0,0" Duration="0:0:0.2" DecelerationRatio="0.9"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Input & Status -->
            <RowDefinition Height="*"/>    <!-- Script List (Takes ALL remaining space) -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- 1. Header Area (Compact) -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Consolidation Dashboard" FontSize="24" FontWeight="Bold" Foreground="#4527A0"/>
                <TextBlock Text="Extract, Sort, and Merge scripts with precision" FontSize="12" Opacity="0.6" Margin="0,2,0,0"/>
            </StackPanel>
            
            <Border Grid.Column="1" Background="#EDE7F6" CornerRadius="50" Width="40" Height="40">
                <materialDesign:PackIcon Kind="DatabaseSync" Width="20" Height="20" Foreground="#4527A0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- 2. Main Action Card (Compacted) -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/> <!-- Input (Smaller) -->
                <ColumnDefinition Width="20"/> <!-- Spacing -->
                <ColumnDefinition Width="300"/> <!-- Status (Fixed Width) -->
            </Grid.ColumnDefinitions>

            <!-- Input Section (Target Tickets) -->
            <materialDesign:Card Grid.Column="0" Padding="15" UniformCornerRadius="10" materialDesign:ShadowAssist.ShadowDepth="Depth2"
                                 AllowDrop="True">
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="Drop">
                        <b:InvokeCommandAction Command="{Binding DropCommand}" PassEventArgsToCommand="True"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <materialDesign:PackIcon Kind="TicketConfirmationOutline" Foreground="#5E35B1" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Target Tickets / Drop Files Here" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <TextBox materialDesign:HintAssist.Hint="Enter ticket numbers (e.g. Engage-11333)" 
                             materialDesign:HintAssist.Foreground="{DynamicResource PrimaryHueDarkBrush}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                             Height="40"
                             Text="{Binding TicketInput, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsScanRunning, Converter={StaticResource InverseBooleanConverter}}"
                             BorderBrush="#B39DDB"
                             materialDesign:TextFieldAssist.TextFieldCornerRadius="6"
                             FontSize="12"
                             Padding="8"
                             Foreground="Black"
                             VerticalContentAlignment="Center"/>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="RESET" 
                                Command="{Binding ClearCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                BorderBrush="#D32F2F"
                                Foreground="#D32F2F"
                                Height="32"
                                Width="80"
                                FontSize="10"
                                materialDesign:ButtonAssist.CornerRadius="6"/>

                        <!-- Spacer -->
                        
                        <Button Grid.Column="2" 
                                Content="UPLOAD FILE"
                                Command="{Binding UploadFileCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                BorderBrush="#5E35B1"
                                Foreground="#5E35B1"
                                Height="32"
                                Width="100"
                                FontSize="10"
                                materialDesign:ButtonAssist.CornerRadius="6"/>

                        <!-- Scan / Stop Toggle -->
                        <Grid Grid.Column="4">
                            <!-- SCAN Button (Visible when NOT running) -->
                            <Button Content="SCAN &amp; PROCESS" 
                                    Command="{Binding ScanCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="#5E35B1"
                                    BorderBrush="#5E35B1"
                                    Height="32"
                                    Width="120"
                                    FontSize="10"
                                    materialDesign:ButtonAssist.CornerRadius="6"
                                    Visibility="{Binding IsScanRunning, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                            <!-- STOP Button (Visible when RUNNING) -->
                            <Button Content="STOP SCAN" 
                                    Command="{Binding StopScanCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="#D32F2F"
                                    BorderBrush="#D32F2F"
                                    Height="32"
                                    Width="120"
                                    FontSize="10"
                                    materialDesign:ButtonAssist.CornerRadius="6"
                                    Visibility="{Binding IsScanRunning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Grid>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- Status & Stats Section -->
            <materialDesign:Card Grid.Column="2" Padding="15" UniformCornerRadius="10" Background="{DynamicResource PrimaryHueMidBrush}" Foreground="White" materialDesign:ShadowAssist.ShadowDepth="Depth2">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="SYSTEM STATUS" FontSize="9" Opacity="0.7" FontWeight="Bold"/>
                        <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,5,0,8" FontSize="11" FontWeight="SemiBold" MaxHeight="35" TextTrimming="CharacterEllipsis"/>
                        
                        <ProgressBar Value="{Binding ProgressValue}" Maximum="100" Height="4" 
                                     Background="#50FFFFFF" Foreground="#00E5FF" 
                                     BorderThickness="0"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <Separator Background="White" Opacity="0.1" Margin="0,10"/>
                        
                        <TextBlock Text="FOUND OBJECTS" FontSize="9" Opacity="0.7" FontWeight="Bold" Margin="0,0,0,5"/>
                        <UniformGrid Columns="5">
                            <StackPanel>
                                <TextBlock Text="{Binding TicketsCount}" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="Tickets" FontSize="9" Opacity="0.7"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{Binding TableCount}" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="Tables" FontSize="9" Opacity="0.7"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{Binding SpCount}" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="SPs" FontSize="9" Opacity="0.7"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{Binding TriggerCount}" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="Triggers" FontSize="9" Opacity="0.7"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{Binding DataCount}" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="Data" FontSize="9" Opacity="0.7"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </Grid>

        <!-- 3. Results List (Expanded Area) -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Extracted Scripts (Ready for Merge)" FontSize="13" FontWeight="SemiBold" Margin="5,0,0,8" Foreground="#424242"/>

            <!-- 4 Columns Layout -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Tables Column -->
                <materialDesign:Card Grid.Column="0" UniformCornerRadius="8" Padding="0" materialDesign:ShadowAssist.ShadowDepth="Depth1" VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="#E8EAF6" CornerRadius="8,8,0,0" Padding="12">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Table" Foreground="#3F51B5" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Tables" FontWeight="Bold" Foreground="#3949AB" FontSize="13"/>
                                <TextBlock Text="{Binding TableScripts.Count, StringFormat=' ({0})'}" Foreground="#7986CB" FontSize="13"/>
                            </StackPanel>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                            <ItemsControl ItemsSource="{Binding TableScripts}" ItemsPanel="{StaticResource FluidItemsPanel}">
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter" BasedOn="{StaticResource SlideInAnimation}"/>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <materialDesign:Card Margin="0,0,0,8" Padding="10" Style="{StaticResource CardHoverStyle}" UniformCornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding TicketNumber}" FontWeight="Bold" Foreground="#37474F" FontSize="11"/>
                                                    <TextBlock Text="{Binding SourceFile}" FontSize="9" Foreground="#90A4AE" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}" 
                                                            Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                            CommandParameter="{Binding}" 
                                                            Height="24" Width="24" Foreground="#4CAF50"
                                                            Visibility="{Binding IsFirst, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                                            ToolTip="Move Up">
                                                        <materialDesign:PackIcon Kind="ArrowUpBold" Width="18" Height="18"/>
                                                    </Button>
                                                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}" 
                                                            Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                            CommandParameter="{Binding}" 
                                                            Height="24" Width="24" Foreground="#F44336"
                                                            Visibility="{Binding IsLast, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                                            ToolTip="Move Down">
                                                        <materialDesign:PackIcon Kind="ArrowDownBold" Width="18" Height="18"/>
                                                    </Button>
                                                             <!-- Remove Button -->
                                                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}" 
                                                            Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                            CommandParameter="{Binding}" 
                                                            Height="24" Width="24" Foreground="#757575"
                                                            ToolTip="Remove Script"
                                                            Margin="5,0,0,0">
                                                        <materialDesign:PackIcon Kind="DeleteOutline" Width="18" Height="18"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </materialDesign:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </materialDesign:Card>

                <!-- SPs Column -->
                <materialDesign:Card Grid.Column="2" UniformCornerRadius="8" Padding="0" materialDesign:ShadowAssist.ShadowDepth="Depth1" VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="#E3F2FD" CornerRadius="8,8,0,0" Padding="12">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Function" Foreground="#1E88E5" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Stored Procedures" FontWeight="Bold" Foreground="#1565C0" FontSize="13"/>
                                <TextBlock Text="{Binding SpScripts.Count, StringFormat=' ({0})'}" Foreground="#64B5F6" FontSize="13"/>
                            </StackPanel>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                            <ItemsControl ItemsSource="{Binding SpScripts}" ItemsPanel="{StaticResource FluidItemsPanel}">
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter" BasedOn="{StaticResource SlideInAnimation}"/>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <materialDesign:Card Margin="0,0,0,8" Padding="10" Style="{StaticResource CardHoverStyle}" UniformCornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding TicketNumber}" FontWeight="Bold" Foreground="#37474F" FontSize="11"/>
                                                    <TextBlock Text="{Binding SourceFile}" FontSize="9" Foreground="#90A4AE" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}" 
                                                            Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                            CommandParameter="{Binding}" 
                                                            Height="24" Width="24" Foreground="#4CAF50"
                                                            Visibility="{Binding IsFirst, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                                            ToolTip="Move Up">
                                                        <materialDesign:PackIcon Kind="ArrowUpBold" Width="18" Height="18"/>
                                                    </Button>
                                                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}" 
                                                            Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                            CommandParameter="{Binding}" 
                                                            Height="24" Width="24" Foreground="#F44336"
                                                            Visibility="{Binding IsLast, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                                            ToolTip="Move Down">
                                                        <materialDesign:PackIcon Kind="ArrowDownBold" Width="18" Height="18"/>
                                                    </Button>
                                                             <!-- Remove Button -->
                                                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}" 
                                                            Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                            CommandParameter="{Binding}" 
                                                            Height="24" Width="24" Foreground="#757575"
                                                            ToolTip="Remove Script"
                                                            Margin="5,0,0,0">
                                                        <materialDesign:PackIcon Kind="DeleteOutline" Width="18" Height="18"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </materialDesign:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </materialDesign:Card>

                <!-- Triggers Column -->
                <materialDesign:Card Grid.Column="4" UniformCornerRadius="8" Padding="0" materialDesign:ShadowAssist.ShadowDepth="Depth1" VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="#F3E5F5" CornerRadius="8,8,0,0" Padding="12">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="LightningBolt" Foreground="#8E24AA" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Triggers" FontWeight="Bold" Foreground="#7B1FA2" FontSize="13"/>
                                <TextBlock Text="{Binding TriggerScripts.Count, StringFormat=' ({0})'}" Foreground="#BA68C8" FontSize="13"/>
                            </StackPanel>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                            <ItemsControl ItemsSource="{Binding TriggerScripts}" ItemsPanel="{StaticResource FluidItemsPanel}">
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter" BasedOn="{StaticResource SlideInAnimation}"/>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <materialDesign:Card Margin="0,0,0,8" Padding="10" Style="{StaticResource CardHoverStyle}" UniformCornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding TicketNumber}" FontWeight="Bold" Foreground="#37474F" FontSize="11"/>
                                                    <TextBlock Text="{Binding SourceFile}" FontSize="9" Foreground="#90A4AE" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}" 
                                                            Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                            CommandParameter="{Binding}" 
                                                            Height="24" Width="24" Foreground="#4CAF50"
                                                            Visibility="{Binding IsFirst, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                                            ToolTip="Move Up">
                                                        <materialDesign:PackIcon Kind="ArrowUpBold" Width="18" Height="18"/>
                                                    </Button>
                                                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}" 
                                                            Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                            CommandParameter="{Binding}" 
                                                            Height="24" Width="24" Foreground="#F44336"
                                                            Visibility="{Binding IsLast, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                                            ToolTip="Move Down">
                                                        <materialDesign:PackIcon Kind="ArrowDownBold" Width="18" Height="18"/>
                                                    </Button>
                                                             <!-- Remove Button -->
                                                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}" 
                                                            Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                            CommandParameter="{Binding}" 
                                                            Height="24" Width="24" Foreground="#757575"
                                                            ToolTip="Remove Script"
                                                            Margin="5,0,0,0">
                                                        <materialDesign:PackIcon Kind="DeleteOutline" Width="18" Height="18"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </materialDesign:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </materialDesign:Card>

                <!-- Data Column -->
                <materialDesign:Card Grid.Column="6" UniformCornerRadius="8" Padding="0" materialDesign:ShadowAssist.ShadowDepth="Depth1" VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="#E0F2F1" CornerRadius="8,8,0,0" Padding="12">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Database" Foreground="#00897B" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Data / Inserts" FontWeight="Bold" Foreground="#00695C" FontSize="13"/>
                                <TextBlock Text="{Binding DataScripts.Count, StringFormat=' ({0})'}" Foreground="#4DB6AC" FontSize="13"/>
                            </StackPanel>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                            <ItemsControl ItemsSource="{Binding DataScripts}" ItemsPanel="{StaticResource FluidItemsPanel}">
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter" BasedOn="{StaticResource SlideInAnimation}"/>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <materialDesign:Card Margin="0,0,0,8" Padding="10" Style="{StaticResource CardHoverStyle}" UniformCornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding TicketNumber}" FontWeight="Bold" Foreground="#37474F" FontSize="11"/>
                                                    <TextBlock Text="{Binding SourceFile}" FontSize="9" Foreground="#90A4AE" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}" 
                                                            Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                            CommandParameter="{Binding}" 
                                                            Height="24" Width="24" Foreground="#4CAF50"
                                                            Visibility="{Binding IsFirst, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                                            ToolTip="Move Up">
                                                        <materialDesign:PackIcon Kind="ArrowUpBold" Width="18" Height="18"/>
                                                    </Button>
                                                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}" 
                                                            Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                            CommandParameter="{Binding}" 
                                                            Height="24" Width="24" Foreground="#F44336"
                                                            Visibility="{Binding IsLast, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                                            ToolTip="Move Down">
                                                        <materialDesign:PackIcon Kind="ArrowDownBold" Width="18" Height="18"/>
                                                    </Button>
                                                             <!-- Remove Button -->
                                                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}" 
                                                            Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                            CommandParameter="{Binding}" 
                                                            Height="24" Width="24" Foreground="#757575"
                                                            ToolTip="Remove Script"
                                                            Margin="5,0,0,0">
                                                        <materialDesign:PackIcon Kind="DeleteOutline" Width="18" Height="18"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </materialDesign:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </Grid>

        <!-- 4. Footer -->
        <Grid Grid.Row="3" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="CONSOLIDATE &amp; SAVE FILES" 
                    Command="{Binding ConsolidateCommand}"
                    Height="45"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="#2E7D32"
                    BorderBrush="#2E7D32"
                    FontSize="13"
                    FontWeight="Bold"
                    materialDesign:ButtonAssist.CornerRadius="6"
                    materialDesign:ShadowAssist.ShadowDepth="Depth2"/>

            <Button Grid.Column="2"
                    Content="CREATE RELEASE EMAIL" 
                    Command="{Binding CreateReleaseEmailCommand}"
                    Height="45"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="#1565C0"
                    BorderBrush="#1565C0"
                    FontSize="13"
                    FontWeight="Bold"
