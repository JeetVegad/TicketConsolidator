<UserControl x:Class="TicketConsolidator.UI.Views.Dialogs.LoginDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Width="420"
             Background="Transparent"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             FontFamily="{DynamicResource MaterialDesignFont}">

    <materialDesign:Card UniformCornerRadius="12" Background="White" Padding="30" materialDesign:ShadowAssist.ShadowDepth="Depth0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Icon -->
            <materialDesign:PackIcon Kind="ShieldLock" Width="48" Height="48"
                                     Foreground="{DynamicResource PrimaryHueMidBrush}" 
                                     HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <!-- Title -->
            <TextBlock Grid.Row="1" Text="Jira Login" FontSize="20" FontWeight="Bold" 
                       Foreground="{DynamicResource PrimaryHueMidBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,5"/>

            <TextBlock Grid.Row="2" Text="Enter your credentials to connect to Jira"
                       FontSize="12" Opacity="0.6" HorizontalAlignment="Center" 
                       Margin="0,0,0,20" Foreground="#424242"/>

            <!-- Email/Username -->
            <TextBox x:Name="UsernameBox" Grid.Row="3"
                     materialDesign:HintAssist.Hint="Email / Username"
                     materialDesign:HintAssist.IsFloating="True"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     FontSize="14" Margin="0,0,0,15"/>

            <!-- Password -->
            <PasswordBox x:Name="PasswordBox" Grid.Row="4"
                         materialDesign:HintAssist.Hint="Password"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                         FontSize="14" Margin="0,0,0,25"
                         KeyDown="PasswordBox_KeyDown"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="CANCEL"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="Gray" FontWeight="Bold" Margin="0,0,10,0"
                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                        CommandParameter="{x:Null}"/>

                <Button Content="LOGIN"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        FontWeight="Bold"
                        Click="LoginButton_Click"
                        materialDesign:ButtonAssist.CornerRadius="6"/>
            </StackPanel>
        </Grid>
    </materialDesign:Card>
</UserControl>
