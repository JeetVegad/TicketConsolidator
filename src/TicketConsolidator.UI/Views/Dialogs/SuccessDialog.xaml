<UserControl x:Class="TicketConsolidator.UI.Views.Dialogs.SuccessDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="550"
             Width="500"
             Background="White">
    <Grid Margin="25">
        <Grid.CacheMode>
            <BitmapCache EnableClearType="True" SnapsToDevicePixels="True"/>
        </Grid.CacheMode>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Success Icon -->
        <materialDesign:PackIcon Kind="CheckCircle" 
                                 Foreground="#2E7D32" 
                                 Width="56" Height="56" 
                                 HorizontalAlignment="Center" 
                                 Margin="0,0,0,15"/>

        <!-- Title -->
        <TextBlock Grid.Row="1" 
                   Text="Consolidation Successful!" 
                   FontSize="20" 
                   FontWeight="Bold" 
                   Foreground="#2E7D32" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,10"/>

        <!-- Message / Path -->
        <TextBox Grid.Row="2" 
                   Text="{Binding Message, Mode=OneWay}" 
                   TextWrapping="Wrap" 
                   FontSize="13" 
                   Foreground="#616161" 
                   Background="Transparent"
                   BorderThickness="0"
                   IsReadOnly="True"
                   HorizontalAlignment="Stretch" 
                   HorizontalContentAlignment="Center"
                   TextAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- Action Button -->
        <!-- Action Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            
            <Button Command="{Binding CopyPathCommand}"
                    Content="COPY PATH" 
                    Style="{StaticResource MaterialDesignFlatButton}" 
                    Foreground="#1976D2" 
                    FontSize="14" 
                    FontWeight="Bold"
                    Cursor="Hand"
                    Margin="0,0,20,0"/>

            <Button Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    Content="OK, THANKS" 
                    Style="{StaticResource MaterialDesignFlatButton}" 
                    Foreground="#2E7D32" 
                    FontSize="14" 
                    FontWeight="Bold"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</UserControl>

