<UserControl x:Class="TicketConsolidator.UI.Views.Dialogs.ReleaseDetailsDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Height="450" Width="500">
    <materialDesign:Card UniformCornerRadius="10" Background="White" Margin="10" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Text="Release Details" 
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}" 
                       Foreground="#1976D2" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20"/>

            <!-- Form -->
            <StackPanel Grid.Row="1" Margin="10">
                <!-- Build Number -->
                <TextBox Text="{Binding BuildNumber, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Build Number (e.g. 10.0.123)"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         Margin="0,0,0,20"/>

                <!-- Solution Path -->
                <TextBox Text="{Binding SolutionPath, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Solution Path (Release Folder)"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         Margin="0,0,0,20"/>

                <!-- Username -->
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Your Name (Signature)"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         Margin="0,0,0,10"/>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="CANCEL" 
                        Style="{StaticResource MaterialDesignFlatButton}" 
                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                        CommandParameter="Cancel"
                        Tag="{x:Null}"
                        Margin="0,0,10,0"/>

                <Button Content="GENERATE EMAIL" 
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#1976D2"
                        Foreground="White"
                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                        CommandParameter="Generate"/>
            </StackPanel>
        </Grid>
    </materialDesign:Card>
</UserControl>
