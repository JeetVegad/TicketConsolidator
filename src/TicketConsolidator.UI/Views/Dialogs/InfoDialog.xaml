<UserControl x:Class="TicketConsolidator.UI.Views.Dialogs.InfoDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="650"
             Width="600"
             Background="Transparent"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             TextElement.FontWeight="Regular"
             TextElement.FontSize="13"
             TextOptions.TextFormattingMode="Ideal"
             TextOptions.TextRenderingMode="Auto"
             FontFamily="{DynamicResource MaterialDesignFont}">

    <materialDesign:Card UniformCornerRadius="12" Background="White" Padding="25" materialDesign:ShadowAssist.ShadowDepth="Depth0">
        <materialDesign:Card.CacheMode>
            <BitmapCache EnableClearType="True" SnapsToDevicePixels="True"/>
        </materialDesign:Card.CacheMode>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Icon -->
            <materialDesign:PackIcon Kind="{Binding IconKind}" 
                                     Foreground="{Binding ColorBrush}" 
                                     Width="56" Height="56" 
                                     HorizontalAlignment="Center" 
                                     Margin="0,0,0,15"/>

            <!-- Title -->
            <TextBlock Grid.Row="1" 
                       Text="{Binding Title}" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Foreground="{Binding ColorBrush}" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,15"/>

            <!-- Message (Selectable, Scrollable) -->
            <TextBox Grid.Row="2" 
                     Text="{Binding Message, Mode=OneWay}" 
                     TextWrapping="Wrap" 
                     FontSize="13"
                     IsReadOnly="True"
                     BorderThickness="0"
                     Background="Transparent"
                     Foreground="#424242"
                     HorizontalAlignment="Stretch"
                     HorizontalContentAlignment="Left"
                     TextAlignment="Left"
                     VerticalScrollBarVisibility="Auto"
                     MaxHeight="150"
                     Margin="0,0,0,25"
                     Padding="5"
                     materialDesign:TextFieldAssist.DecorationVisibility="Hidden"/>

            <!-- Action Button -->
            <Button Grid.Row="3" 
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    Content="OK" 
                    Style="{StaticResource MaterialDesignFlatButton}" 
                    Foreground="{Binding ColorBrush}" 
                    FontWeight="Bold"
                    FontSize="14" 
                    HorizontalAlignment="Right"
                    Cursor="Hand"
                    materialDesign:ButtonAssist.CornerRadius="4"/>
        </Grid>
    </materialDesign:Card>
</UserControl>
