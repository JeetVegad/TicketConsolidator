<UserControl x:Class="TicketConsolidator.UI.Views.HelpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto" CanContentScroll="False" PanningMode="VerticalOnly">
        <StackPanel Margin="20">
            
            <!-- HEADER / ABOUT -->
            <materialDesign:Card Margin="0,0,0,20" Padding="20" UniformCornerRadius="8" materialDesign:ShadowAssist.ShadowDepth="Depth1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <materialDesign:PackIcon Kind="InformationOutline" Width="48" Height="48" Foreground="{DynamicResource PrimaryHueLightBrush}" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Ticket Consolidator" Style="{StaticResource MaterialDesignHeadline5TextBlock}" FontWeight="Bold" Foreground="{DynamicResource MaterialDesignBody}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Text="Version: " Foreground="Gray"/>
                            <TextBlock Text="{Binding AppVersion, FallbackValue='v1.0.0'}" FontWeight="Bold" Margin="0,0,15,0"/>
                            <TextBlock Text="Built: " Foreground="Gray"/>
                            <TextBlock Text="{Binding BuildDate}" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <!-- USER GUIDE -->
            <TextBlock Text="User Guide" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,10"/>
            <materialDesign:Card Margin="0,0,0,20" UniformCornerRadius="8" x:Name="UserGuideCard">
                <materialDesign:Card.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="UserGuideCard" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </materialDesign:Card.Triggers>
                <StackPanel>
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Numeric1Circle" Foreground="{DynamicResource PrimaryHueLightBrush}" Width="24" Height="24" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                            <materialDesign:PackIcon.RenderTransform> <ScaleTransform ScaleX="0" ScaleY="0"/> </materialDesign:PackIcon.RenderTransform>
                            <materialDesign:PackIcon.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.4" BeginTime="0:0:0.5">
                                                 <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.4" BeginTime="0:0:0.5">
                                                 <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </materialDesign:PackIcon.Triggers>
                        </materialDesign:PackIcon>
                        <TextBlock Grid.Column="1" Text="Enter Ticket Numbers (e.g. TICKET-123, TICKET-456) in the Dashboard input." VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Grid>
                    <Separator/>
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Numeric2Circle" Foreground="{DynamicResource PrimaryHueLightBrush}" Width="24" Height="24" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                            <materialDesign:PackIcon.RenderTransform> <ScaleTransform ScaleX="0" ScaleY="0"/> </materialDesign:PackIcon.RenderTransform>
                            <materialDesign:PackIcon.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.4" BeginTime="0:0:0.7">
                                                 <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.4" BeginTime="0:0:0.7">
                                                 <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </materialDesign:PackIcon.Triggers>
                        </materialDesign:PackIcon>
                        <TextBlock Grid.Column="1" Text="Click 'SCAN' to search your Outlook emails for attachments." VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Grid>
                    <Separator/>
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Numeric3Circle" Foreground="{DynamicResource PrimaryHueLightBrush}" Width="24" Height="24" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                            <materialDesign:PackIcon.RenderTransform> <ScaleTransform ScaleX="0" ScaleY="0"/> </materialDesign:PackIcon.RenderTransform>
                            <materialDesign:PackIcon.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.4" BeginTime="0:0:0.9">
                                                 <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.4" BeginTime="0:0:0.9">
                                                 <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </materialDesign:PackIcon.Triggers>
                        </materialDesign:PackIcon>
                        <TextBlock Grid.Column="1" Text="Review found scripts. Use Up/Down arrows to reorder them if needed." VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Grid>
                    <Separator/>
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Numeric4Circle" Foreground="{DynamicResource PrimaryHueLightBrush}" Width="24" Height="24" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                            <materialDesign:PackIcon.RenderTransform> <ScaleTransform ScaleX="0" ScaleY="0"/> </materialDesign:PackIcon.RenderTransform>
                            <materialDesign:PackIcon.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.4" BeginTime="0:0:1.1">
                                                 <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.4" BeginTime="0:0:1.1">
                                                 <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </materialDesign:PackIcon.Triggers>
                        </materialDesign:PackIcon>
                        <TextBlock Grid.Column="1" Text="Click 'CONSOLIDATE' to merge them into final SQL files." VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- VISUAL WORKFLOW - ENHANCED ANIMATED STORY -->
            <TextBlock Text="Interactive Workflow Story" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,5"/>
            <TextBlock Text="Watch how the application processes your tickets from input to release" FontSize="12" Opacity="0.7" Margin="0,0,0,10" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
            
            <!-- DETAILED WORKFLOW ANIMATION -->
            <materialDesign:Card Margin="0,0,0,20" Padding="25" UniformCornerRadius="8" ClipToBounds="False">
                <StackPanel>
                    <!-- Step 1: Input Tickets -->
                    <Border Background="{DynamicResource MaterialDesignDivider}" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <Grid Height="100">
                            <Grid.Resources>
                                <Storyboard x:Key="InputAnimation" RepeatBehavior="Forever">
                                    <!-- Cursor blinking -->
                                    <DoubleAnimation Storyboard.TargetName="Cursor" Storyboard.TargetProperty="Opacity"
                                                   From="1" To="0" Duration="0:0:0.8" AutoReverse="True"/>
                                    <!-- Ticket badges appearing -->
                                    <DoubleAnimation Storyboard.TargetName="Ticket1" Storyboard.TargetProperty="Opacity"
                                                   From="0" To="1" Duration="0:0:0.3" BeginTime="0:0:0.5"/>
                                    <DoubleAnimation Storyboard.TargetName="Ticket2" Storyboard.TargetProperty="Opacity"
                                                   From="0" To="1" Duration="0:0:0.3" BeginTime="0:0:1.5"/>
                                    <DoubleAnimation Storyboard.TargetName="Ticket3" Storyboard.TargetProperty="Opacity"
                                                   From="0" To="1" Duration="0:0:0.3" BeginTime="0:0:2.5"/>
                                </Storyboard>
                            </Grid.Resources>
                            <Grid.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard Storyboard="{StaticResource InputAnimation}"/>
                                </EventTrigger>
                            </Grid.Triggers>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <materialDesign:PackIcon Kind="KeyboardOutline" Width="60" Height="60" 
                                                   Foreground="{DynamicResource PrimaryHueMidBrush}" 
                                                   VerticalAlignment="Center" Margin="0,0,20,0"/>
                            
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Step 1: Enter Ticket Numbers" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                                <Border Background="{DynamicResource MaterialDesignPaper}" BorderBrush="{DynamicResource MaterialDesignDivider}" 
                                      BorderThickness="1" CornerRadius="4" Padding="8">
                                    <StackPanel Orientation="Horizontal">
                                        <Border x:Name="Ticket1" Background="{DynamicResource PrimaryHueLightBrush}" CornerRadius="12" 
                                              Padding="8,4" Margin="0,0,5,0" Opacity="0">
                                            <TextBlock Text="TICKET-123" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                        <Border x:Name="Ticket2" Background="{DynamicResource PrimaryHueMidBrush}" CornerRadius="12" 
                                              Padding="8,4" Margin="0,0,5,0" Opacity="0">
                                            <TextBlock Text="TICKET-456" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                        <Border x:Name="Ticket3" Background="{DynamicResource SecondaryHueLightBrush}" CornerRadius="12" 
                                              Padding="8,4" Margin="0,0,5,0" Opacity="0">
                                            <TextBlock Text="TICKET-789" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                        <Rectangle x:Name="Cursor" Width="2" Height="16" Fill="{DynamicResource PrimaryHueMidBrush}" 
                                                 VerticalAlignment="Center" Margin="5,0,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Step 2: Email Scanning -->
                    <Border Background="#E3F2FD" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <Grid Height="100">
                            <Grid.Resources>
                                <Storyboard x:Key="ScanAnimation" RepeatBehavior="Forever">
                                    <!-- Email envelopes floating in -->
                                    <DoubleAnimation Storyboard.TargetName="Email1" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                   From="50" To="0" Duration="0:0:1" BeginTime="0:0:0">
                                        <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="Email1" Storyboard.TargetProperty="Opacity"
                                                   From="0" To="1" Duration="0:0:1" BeginTime="0:0:0"/>
                                    
                                    <DoubleAnimation Storyboard.TargetName="Email2" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                   From="50" To="0" Duration="0:0:1" BeginTime="0:0:0.3">
                                        <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="Email2" Storyboard.TargetProperty="Opacity"
                                                   From="0" To="1" Duration="0:0:1" BeginTime="0:0:0.3"/>
                                    
                                    <DoubleAnimation Storyboard.TargetName="Email3" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                   From="50" To="0" Duration="0:0:1" BeginTime="0:0:0.6">
                                        <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="Email3" Storyboard.TargetProperty="Opacity"
                                                   From="0" To="1" Duration="0:0:1" BeginTime="0:0:0.6"/>
                                    
                                    <!-- Search radar animation -->
                                    <DoubleAnimation Storyboard.TargetName="SearchRadar" Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                   From="0" To="360" Duration="0:0:2" RepeatBehavior="Forever"/>
                                </Storyboard>
                            </Grid.Resources>
                            <Grid.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard Storyboard="{StaticResource ScanAnimation}"/>
                                </EventTrigger>
                            </Grid.Triggers>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Grid VerticalAlignment="Center" Margin="0,0,20,0">
                                <materialDesign:PackIcon Kind="EmailSearch" Width="60" Height="60" Foreground="#1976D2"/>
                                <materialDesign:PackIcon x:Name="SearchRadar" Kind="Radar" Width="30" Height="30" 
                                                       Foreground="#2196F3" Opacity="0.6" RenderTransformOrigin="0.5,0.5">
                                    <materialDesign:PackIcon.RenderTransform>
                                        <RotateTransform Angle="0"/>
                                    </materialDesign:PackIcon.RenderTransform>
                                </materialDesign:PackIcon>
                            </Grid>
                            
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Step 2: Scan Outlook Emails" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon x:Name="Email1" Kind="Email" Width="24" Height="24" 
                                                           Foreground="#1976D2" Margin="0,0,10,0" Opacity="0">
                                        <materialDesign:PackIcon.RenderTransform><TranslateTransform Y="0"/></materialDesign:PackIcon.RenderTransform>
                                    </materialDesign:PackIcon>
                                    <materialDesign:PackIcon x:Name="Email2" Kind="Email" Width="24" Height="24" 
                                                           Foreground="#42A5F5" Margin="0,0,10,0" Opacity="0">
                                        <materialDesign:PackIcon.RenderTransform><TranslateTransform Y="0"/></materialDesign:PackIcon.RenderTransform>
                                    </materialDesign:PackIcon>
                                    <materialDesign:PackIcon x:Name="Email3" Kind="Email" Width="24" Height="24" 
                                                           Foreground="#64B5F6" Margin="0,0,10,0" Opacity="0">
                                        <materialDesign:PackIcon.RenderTransform><TranslateTransform Y="0"/></materialDesign:PackIcon.RenderTransform>
                                    </materialDesign:PackIcon>
                                    <TextBlock Text="Finding attachments..." FontStyle="Italic" FontSize="12" VerticalAlignment="Center" Foreground="#1976D2"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Step 3: Script Categorization -->
                    <Border Background="#FFF3E0" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <Grid Height="120">
                            <Grid.Resources>
                                <Storyboard x:Key="CategoryAnimation" RepeatBehavior="Forever">
                                    <!-- Script flying to categories -->
                                    <DoubleAnimation Storyboard.TargetName="ScriptToTable" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                   From="0" To="-80" Duration="0:0:1" BeginTime="0:0:0.5"/>
                                    <DoubleAnimation Storyboard.TargetName="ScriptToTable" Storyboard.TargetProperty="Opacity"
                                                   From="1" To="0" Duration="0:0:1" BeginTime="0:0:0.5"/>
                                    
                                    <DoubleAnimation Storyboard.TargetName="ScriptToSP" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                   From="0" To="-30" Duration="0:0:1" BeginTime="0:0:1"/>
                                    <DoubleAnimation Storyboard.TargetName="ScriptToSP" Storyboard.TargetProperty="Opacity"
                                                   From="1" To="0" Duration="0:0:1" BeginTime="0:0:1"/>
                                    
                                    <DoubleAnimation Storyboard.TargetName="ScriptToTrigger" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                   From="0" To="30" Duration="0:0:1" BeginTime="0:0:1.5"/>
                                    <DoubleAnimation Storyboard.TargetName="ScriptToTrigger" Storyboard.TargetProperty="Opacity"
                                                   From="1" To="0" Duration="0:0:1" BeginTime="0:0:1.5"/>
                                    
                                    <DoubleAnimation Storyboard.TargetName="ScriptToData" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                   From="0" To="80" Duration="0:0:1" BeginTime="0:0:2"/>
                                    <DoubleAnimation Storyboard.TargetName="ScriptToData" Storyboard.TargetProperty="Opacity"
                                                   From="1" To="0" Duration="0:0:1" BeginTime="0:0:2"/>
                                    
                                    <!-- Category badges growing -->
                                    <DoubleAnimation Storyboard.TargetName="TableBadge" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                   From="1" To="1.2" Duration="0:0:0.2" BeginTime="0:0:1.5" AutoReverse="True"/>
                                    <DoubleAnimation Storyboard.TargetName="TableBadge" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                   From="1" To="1.2" Duration="0:0:0.2" BeginTime="0:0:1.5" AutoReverse="True"/>
                                </Storyboard>
                            </Grid.Resources>
                            <Grid.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard Storyboard="{StaticResource CategoryAnimation}"/>
                                </EventTrigger>
                            </Grid.Triggers>
                            
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Step 3: Extract &amp; Categorize Scripts" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Left side: Categories -->
                                    <UniformGrid Grid.Column="0" Columns="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border x:Name="TableBadge" Background="#4CAF50" CornerRadius="4" Padding="6,4" Margin="2" RenderTransformOrigin="0.5,0.5">
                                            <Border.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                                            <StackPanel HorizontalAlignment="Center">
                                                <materialDesign:PackIcon Kind="Table" Width="16" Height="16" Foreground="White" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Tables" FontSize="8" Foreground="White" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#2196F3" CornerRadius="4" Padding="6,4" Margin="2">
                                            <StackPanel HorizontalAlignment="Center">
                                                <materialDesign:PackIcon Kind="Function" Width="16" Height="16" Foreground="White" HorizontalAlignment="Center"/>
                                                <TextBlock Text="SPs" FontSize="8" Foreground="White" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#FF9800" CornerRadius="4" Padding="6,4" Margin="2">
                                            <StackPanel HorizontalAlignment="Center">
                                                <materialDesign:PackIcon Kind="LightningBolt" Width="16" Height="16" Foreground="White" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Triggers" FontSize="8" Foreground="White" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#9C27B0" CornerRadius="4" Padding="6,4" Margin="2">
                                            <StackPanel HorizontalAlignment="Center">
                                                <materialDesign:PackIcon Kind="Database" Width="16" Height="16" Foreground="White" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Data" FontSize="8" Foreground="White" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>
                                    
                                    <!-- Center: Arrow -->
                                    <materialDesign:PackIcon Grid.Column="1" Kind="ArrowLeftBold" Width="30" Height="30" 
                                                           Foreground="#FF6F00" VerticalAlignment="Center" Margin="10,0"/>
                                    
                                    <!-- Right side: Scripts flying -->
                                    <Grid Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <materialDesign:PackIcon x:Name="ScriptToTable" Kind="FileDocument" Width="20" Height="20" 
                                                                   Foreground="#4CAF50" Margin="3" Opacity="1">
                                                <materialDesign:PackIcon.RenderTransform><TranslateTransform X="0"/></materialDesign:PackIcon.RenderTransform>
                                            </materialDesign:PackIcon>
                                            <materialDesign:PackIcon x:Name="ScriptToSP" Kind="FileDocument" Width="20" Height="20" 
                                                                   Foreground="#2196F3" Margin="3" Opacity="1">
                                                <materialDesign:PackIcon.RenderTransform><TranslateTransform X="0"/></materialDesign:PackIcon.RenderTransform>
                                            </materialDesign:PackIcon>
                                            <materialDesign:PackIcon x:Name="ScriptToTrigger" Kind="FileDocument" Width="20" Height="20" 
                                                                   Foreground="#FF9800" Margin="3" Opacity="1">
                                                <materialDesign:PackIcon.RenderTransform><TranslateTransform X="0"/></materialDesign:PackIcon.RenderTransform>
                                            </materialDesign:PackIcon>
                                            <materialDesign:PackIcon x:Name="ScriptToData" Kind="FileDocument" Width="20" Height="20" 
                                                                   Foreground="#9C27B0" Margin="3" Opacity="1">
                                                <materialDesign:PackIcon.RenderTransform><TranslateTransform X="0"/></materialDesign:PackIcon.RenderTransform>
                                            </materialDesign:PackIcon>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Step 4: Consolidation & Output -->
                    <Border Background="#E8F5E9" CornerRadius="8" Padding="15">
                        <Grid Height="100">
                            <Grid.Resources>
                                <Storyboard x:Key="OutputAnimation" RepeatBehavior="Forever">
                                    <!-- Gears rotating -->
                                    <DoubleAnimation Storyboard.TargetName="Gear1" Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                   From="0" To="360" Duration="0:0:3"/>
                                    <DoubleAnimation Storyboard.TargetName="Gear2" Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                   From="360" To="0" Duration="0:0:3"/>
                                    
                                    <!-- Output file appearing -->
                                    <DoubleAnimation Storyboard.TargetName="OutputFile" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                   From="0" To="1" Duration="0:0:0.5" BeginTime="0:0:2">
                                        <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="OutputFile" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                   From="0" To="1" Duration="0:0:0.5" BeginTime="0:0:2">
                                        <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="OutputFile" Storyboard.TargetProperty="Opacity"
                                                   From="0" To="1" Duration="0:0:0.5" BeginTime="0:0:2"/>
                                </Storyboard>
                            </Grid.Resources>
                            <Grid.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard Storyboard="{StaticResource OutputAnimation}"/>
                                </EventTrigger>
                            </Grid.Triggers>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <Grid VerticalAlignment="Center" Margin="0,0,20,0">
                                <materialDesign:PackIcon x:Name="Gear1" Kind="Cog" Width="40" Height="40" 
                                                       Foreground="#2E7D32" RenderTransformOrigin="0.5,0.5">
                                    <materialDesign:PackIcon.RenderTransform><RotateTransform Angle="0"/></materialDesign:PackIcon.RenderTransform>
                                </materialDesign:PackIcon>
                                <materialDesign:PackIcon x:Name="Gear2" Kind="Cog" Width="25" Height="25" 
                                                       Foreground="#43A047" RenderTransformOrigin="0.5,0.5" Margin="25,25,0,0">
                                    <materialDesign:PackIcon.RenderTransform><RotateTransform Angle="0"/></materialDesign:PackIcon.RenderTransform>
                                </materialDesign:PackIcon>
                            </Grid>
                            
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Step 4: Consolidate &amp; Generate Output" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                                <TextBlock Text="Merging scripts with global SQL headers/footers and ticket wrappers..." 
                                         FontSize="11" Foreground="#2E7D32" FontStyle="Italic"/>
                            </StackPanel>
                            
                            <materialDesign:PackIcon x:Name="OutputFile" Grid.Column="2" Kind="FileCheck" Width="50" Height="50" 
                                                   Foreground="#4CAF50" VerticalAlignment="Center" Opacity="0" RenderTransformOrigin="0.5,0.5">
                                <materialDesign:PackIcon.RenderTransform><ScaleTransform ScaleX="0" ScaleY="0"/></materialDesign:PackIcon.RenderTransform>
                            </materialDesign:PackIcon>
                        </Grid>
                    </Border>
                </StackPanel>
            </materialDesign:Card>

            <!-- SCRIPT FORMATTING RULES -->
            <TextBlock Text="Script Formatting Rules" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,10"/>
            <materialDesign:Card Margin="0,0,0,20" Padding="15" UniformCornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Ensure your .sql attachments use this format so the parser can identify them:" TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <Border Background="{DynamicResource MaterialDesignDivider}" Padding="10" CornerRadius="4">
                        <TextBlock FontFamily="Consolas" FontSize="13" TextWrapping="Wrap">
                            <Run Foreground="#2E7D32">-- &lt;TICKET-123&gt; START</Run><LineBreak/>
                            INSERT INTO Users (Name) VALUES ('John');<LineBreak/>
                            <Run Foreground="#2E7D32">-- &lt;TICKET-123&gt; END</Run>
                        </TextBlock>
                    </Border>
                    <TextBlock Text="* Replace TICKET-123 with your actual ticket number." FontStyle="Italic" FontSize="12" Margin="0,8,0,0"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- FAQ -->
            <TextBlock Text="Troubleshooting / FAQ" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,10"/>
            <StackPanel x:Name="FaqPanel">
                <StackPanel.Triggers>
                     <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="FaqPanel" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.8" BeginTime="0:0:0.5"/>
                                <ThicknessAnimation Storyboard.TargetName="FaqPanel" Storyboard.TargetProperty="Margin" From="0,30,0,0" To="0,0,0,0" Duration="0:0:0.8" BeginTime="0:0:0.5">
                                     <ThicknessAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut"/>
                                    </ThicknessAnimation.EasingFunction>
                                </ThicknessAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </StackPanel.Triggers>
                <Expander Header="Why is my ticket not found?" Margin="0,0,0,5">
                    <TextBlock Text="1. Ensure the email Subject contains the ticket number.&#x0a;2. Check if the email is in the folder specified in Settings (Default: Inbox).&#x0a;3. If it's in a subfolder, update the folder name in Settings." TextWrapping="Wrap" Margin="20"/>
                </Expander>
                <Expander Header="Outlook connection error?" Margin="0,0,0,5">
                    <TextBlock Text="Ensure you are running 'Outlook Classic' application on this machine. The 'New Outlook' (webwrapper) is not supported. Also check that both this app and Outlook are running with the same permissions (e.g. both as Admin or both as User)." TextWrapping="Wrap" Margin="20"/>
                </Expander>
                <Expander Header="How are duplicate scripts handled?" Margin="0,0,0,5">
                    <TextBlock Text="The application processes emails for a ticket in 'Newest First' order. Once a script is found for a ticket in a newer email (e.g. a Reply), any older emails for that same ticket are ignored." TextWrapping="Wrap" Margin="20"/>
                </Expander>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
