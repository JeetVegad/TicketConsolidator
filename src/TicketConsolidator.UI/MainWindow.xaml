<Window x:Class="TicketConsolidator.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TicketConsolidator.UI"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Icon="pack://application:,,,/Assets/app_icon.png"
        WindowState="Maximized"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.ClearTypeHint="Enabled"
        Title="Ticket Consolidator" Height="600" Width="900">
    <materialDesign:DialogHost Identifier="RootDialog"
                               DialogTheme="Inherit" 
                               OverlayBackground="{DynamicResource PrimaryHueDarkBrush}" 
                               DialogMargin="16"
                               CloseOnClickAway="True">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

        <!-- Sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource PrimaryHueMidBrush}">
                <StackPanel Margin="10">
                    <TextBlock Text="Ticket Consolidator" Foreground="White" FontSize="20" FontWeight="Bold" Margin="10,20,10,20"/>
                    
                    <Button Command="{Binding NavigateDashboardCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" HorizontalAlignment="Left" Margin="0,5" Content="DASHBOARD" />
                    <Button Command="{Binding NavigateSettingsCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" HorizontalAlignment="Left" Margin="0,5" Content="SETTINGS" />
                    <Button Command="{Binding NavigateLogsCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" HorizontalAlignment="Left" Margin="0,5" Content="LOGS" />
                    <Button Command="{Binding NavigateHelpCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" HorizontalAlignment="Left" Margin="0,5" Content="HELP" />
                </StackPanel>
            </Border>

            <!-- Main Content Area -->
            <Grid Grid.Column="1" Background="{DynamicResource MaterialDesignPaper}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top Header -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20">
                    <TextBlock VerticalAlignment="Center" Margin="10,0" Text="{Binding CurrentView.DataContext.StatusMessage, FallbackValue='Status: Ready'}" FontStyle="Italic"/>
                </StackPanel>

                <!-- Content Placeholder -->
                <ContentControl Grid.Row="1" Content="{Binding CurrentView}" Margin="20"/>
                
                <materialDesign:Snackbar x:Name="MainSnackbar" Grid.Row="1" MessageQueue="{materialDesign:MessageQueue}" VerticalAlignment="Bottom" Margin="10"/>
            </Grid>
        </Grid>
    </materialDesign:DialogHost>
</Window>
