<Window x:Class="TicketConsolidator.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TicketConsolidator.UI"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Ticket Consolidator" Height="800" Width="1200"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        RenderOptions.BitmapScalingMode="HighQuality"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <materialDesign:DialogHost Identifier="RootDialog"
                               DialogTheme="Inherit" 
                               OverlayBackground="{DynamicResource PrimaryHueDarkBrush}" 
                               DialogMargin="16"
                               CloseOnClickAway="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Navigation Bar -->
            <Border Grid.Row="0" Background="{DynamicResource PrimaryHueMidBrush}" Height="50" Padding="15,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/> <!-- Title -->
                        <ColumnDefinition Width="*"/>    <!-- Spacer -->
                        <ColumnDefinition Width="Auto"/> <!-- Menu -->
                    </Grid.ColumnDefinitions>

                    <!-- App Title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="DatabaseCheck" Width="24" Height="24" Foreground="{DynamicResource PrimaryHueDarkBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="TicketConsolidator" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Navigation Menu -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Command="{Binding NavigateDashboardCommand}" Content="DASHBOARD" Foreground="White" Margin="10,0" Style="{StaticResource MaterialDesignFlatButton}"/>
                        <Button Command="{Binding NavigateCodeReviewCommand}" Content="CODE REVIEW" Foreground="White" Margin="10,0" Style="{StaticResource MaterialDesignFlatButton}"/>
                        <Button Command="{Binding NavigateSettingsCommand}" Content="SETTINGS" Foreground="White" Margin="10,0" Style="{StaticResource MaterialDesignFlatButton}"/>
                        <Button Command="{Binding NavigateLogsCommand}" Content="LOGS" Foreground="White" Margin="10,0" Style="{StaticResource MaterialDesignFlatButton}"/>
                        <Button Command="{Binding NavigateHelpCommand}" Content="HELP" Foreground="White" Margin="10,0" Style="{StaticResource MaterialDesignFlatButton}"/>
                    </StackPanel>
                </Grid>
            </Border>
            <!-- Main Content Area -->
            <Grid Grid.Row="1" Background="{DynamicResource MaterialDesignPaper}">
                <!-- Content Placeholder -->
                <materialDesign:TransitioningContent Content="{Binding CurrentView}" Margin="5">
                    <materialDesign:TransitioningContent.OpeningEffects>
                        <materialDesign:TransitionEffect Kind="FadeIn" Duration="0:0:0.08"/>
                    </materialDesign:TransitioningContent.OpeningEffects>
                </materialDesign:TransitioningContent>
                
                <materialDesign:Snackbar x:Name="MainSnackbar" MessageQueue="{materialDesign:MessageQueue}" VerticalAlignment="Bottom" Margin="10"/>
            </Grid>
        </Grid>
    </materialDesign:DialogHost>
</Window>
